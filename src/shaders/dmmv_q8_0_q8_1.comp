#version 460
// ZINC - Q8_0 weights x Q8_1 activation matrix-vector multiply.
//
// This mirrors llama.cpp's Vulkan mmvq idea for Q8_0: quantize the F32
// activation into Q8_1 blocks, then use integer dot products against Q8_0
// weight blocks. Intended first for the Qwen 3.6 Q8_0 LM head.

#extension GL_EXT_shader_explicit_arithmetic_types : require
#extension GL_EXT_shader_explicit_arithmetic_types_int32 : require
#extension GL_EXT_control_flow_attributes : enable
#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require
#extension GL_EXT_shader_16bit_storage : require

layout(local_size_x = 64) in;

layout(push_constant) uniform PushConstants {
    uint M;
    uint K;
    uint a_offset;
    uint x_offset;
    uint y_offset;
    uint acc_mode;
};

layout(set = 0, binding = 0) readonly buffer MatrixA { uint8_t a_data[]; };
layout(set = 0, binding = 1) readonly buffer VectorXQ81 { uint x_q81[]; };
layout(set = 0, binding = 2) buffer VectorY { float y_data[]; };

const uint Q8_0_BLOCK_SIZE = 32u;
const uint Q8_0_BYTES = 34u;
const uint Q8_1_U32_PER_BLOCK = 9u; // 8 packed int8 quads + packed f16(d, d*sum)

shared float s_sum0[4];
shared float s_sum1[4];

uint load_q8_0_u32(uint qs_off, uint i) {
    const uint q_off = qs_off + i * 4u;
    return
        uint(a_data[q_off + 0u]) |
        (uint(a_data[q_off + 1u]) << 8) |
        (uint(a_data[q_off + 2u]) << 16) |
        (uint(a_data[q_off + 3u]) << 24);
}

int unpack_i8(uint packed, uint lane) {
    const uint byte_val = (packed >> (lane * 8u)) & 0xffu;
    return byte_val < 128u ? int(byte_val) : int(byte_val) - 256;
}

int dot_i8x4(uint a, uint b) {
    int sum = 0;
    [[unroll]] for (uint lane = 0u; lane < 4u; lane++) {
        sum += unpack_i8(a, lane) * unpack_i8(b, lane);
    }
    return sum;
}

float dot_q8_0_q8_1_block(uint qs_off, uint x_block_u32, float d_a) {
    const vec2 ds_b = unpackHalf2x16(x_q81[x_block_u32 + 8u]);
    int q_sum = 0;
    [[unroll]] for (uint i = 0u; i < 8u; i++) {
        q_sum += dot_i8x4(load_q8_0_u32(qs_off, i), x_q81[x_block_u32 + i]);
    }
    return float(q_sum) * d_a * ds_b.x;
}

void main() {
    const uint tid = gl_LocalInvocationID.x;
    const uint row0 = gl_WorkGroupID.x * 2u;
    const uint row1 = row0 + 1u;
    const uint blocks_per_row = K / Q8_0_BLOCK_SIZE;
    const uint row_stride_bytes = blocks_per_row * Q8_0_BYTES;
    const uint x_base_block = x_offset / 36u;

    float sum0 = 0.0;
    float sum1 = 0.0;

    for (uint blk = tid; blk < blocks_per_row; blk += 64u) {
        const uint x_block_u32 = (x_base_block + blk) * Q8_1_U32_PER_BLOCK;

        if (row0 < M) {
            const uint byte_off0 = a_offset + row0 * row_stride_bytes + blk * Q8_0_BYTES;
            const float d0 = unpackHalf2x16(uint(a_data[byte_off0]) | (uint(a_data[byte_off0 + 1u]) << 8)).x;
            sum0 += dot_q8_0_q8_1_block(byte_off0 + 2u, x_block_u32, d0);
        }

        if (row1 < M) {
            const uint byte_off1 = a_offset + row1 * row_stride_bytes + blk * Q8_0_BYTES;
            const float d1 = unpackHalf2x16(uint(a_data[byte_off1]) | (uint(a_data[byte_off1 + 1u]) << 8)).x;
            sum1 += dot_q8_0_q8_1_block(byte_off1 + 2u, x_block_u32, d1);
        }
    }

    sum0 = subgroupAdd(sum0);
    sum1 = subgroupAdd(sum1);

    if (gl_NumSubgroups > 1u) {
        if (subgroupElect()) {
            s_sum0[gl_SubgroupID] = sum0;
            s_sum1[gl_SubgroupID] = sum1;
        }
        barrier();
        if (tid == 0u) {
            sum0 = s_sum0[0];
            sum1 = s_sum1[0];
            for (uint sg = 1u; sg < gl_NumSubgroups; sg++) {
                sum0 += s_sum0[sg];
                sum1 += s_sum1[sg];
            }
        }
    }

    if (tid == 0u) {
        const uint y_base = y_offset / 4u;
        if (acc_mode != 0u) {
            if (row0 < M) y_data[y_base + row0] += sum0;
            if (row1 < M) y_data[y_base + row1] += sum1;
        } else {
            if (row0 < M) y_data[y_base + row0] = sum0;
            if (row1 < M) y_data[y_base + row1] = sum1;
        }
    }
}
