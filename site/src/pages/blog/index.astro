---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const topicLinks = [
  {
    label: 'Qwen3.6 architecture',
    href: '/topics/qwen3-6-local-inference/',
    detail: 'Architecture, GGUF, MoE, MTP',
  },
  {
    label: 'Gemma 4 local inference',
    href: '/topics/gemma-local-inference/',
    detail: 'SWA, GQA, Vulkan, Metal',
  },
  {
    label: 'RDNA4 performance',
    href: '/topics/amd-rdna4-llm-inference/',
    detail: 'R9700, RX 9070 XT, Vulkan',
  },
  {
    label: 'KV cache and quantization',
    href: '/topics/kv-cache-quantization/',
    detail: 'Long context, INT8, TurboQuant',
  },
];
---

<BaseLayout
  title="Local LLM Inference Blog"
  description="Technical posts on ZINC, Qwen3.6, Gemma 4, AMD RDNA4, Vulkan and Metal local LLM inference, KV cache quantization, and GPU performance."
  keywords="ZINC blog, local LLM inference, Qwen3.6, Gemma 4, AMD GPU, RDNA4, Vulkan compute, Metal inference, TurboQuant, GPU optimization, local AI, systems engineering"
>
  <h1>Local LLM Inference Blog</h1>
  <p class="intro">Technical notes on building ZINC, GPU programming, and making local AI work on hardware people actually own.</p>

  <nav class="topic-router" aria-label="Topic guides">
    <span class="topic-router-label">Guides</span>
    {topicLinks.map(topic => (
      <a href={topic.href}>
        <strong>{topic.label}</strong>
        <span>{topic.detail}</span>
      </a>
    ))}
  </nav>

  <section>
    {posts.map(post => (
      <PostCard
        title={post.data.title}
        date={post.data.date}
        excerpt={post.data.excerpt}
        slug={post.id}
        tags={post.data.tags}
      />
    ))}
  </section>
</BaseLayout>

<style>
  .intro {
    color: var(--color-text-muted);
    padding-bottom: var(--space-lg);
  }

  .topic-router {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem;
    padding: var(--space-sm) 0 var(--space-lg);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .topic-router-label {
    margin-right: 0.25rem;
    color: var(--color-text-muted);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .topic-router a {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    min-height: 2.25rem;
    padding: 0.28rem 0.6rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-text);
    text-decoration: none;
  }

  .topic-router a:hover {
    border-color: var(--color-accent);
  }

  .topic-router strong {
    font-size: 0.82rem;
    line-height: 1.2;
  }

  .topic-router span {
    color: var(--color-text-muted);
    font-size: 0.72rem;
    line-height: 1.2;
  }

  @media (max-width: 600px) {
    .topic-router {
      align-items: stretch;
    }

    .topic-router-label {
      width: 100%;
    }

    .topic-router a {
      width: 100%;
      justify-content: space-between;
    }
  }
</style>
