#version 460
// ZINC - SSM delta-net cols8 variant for pre-normalized Q/K.
//
// Expects ssm_qk_norm.comp to have normalized the Q and K slices in conv_out.
// This keeps the reference-style eight-row wave64 update, but removes the
// per-row-block Q/K norm reductions and LDS staging from the hot delta kernel.

#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_ballot : require
#extension GL_KHR_shader_subgroup_arithmetic : require
#extension GL_KHR_shader_subgroup_clustered : require
#extension GL_EXT_shader_explicit_arithmetic_types : require
#extension GL_EXT_shader_16bit_storage : require
#extension GL_EXT_control_flow_attributes : require

layout(local_size_x = 64) in;

layout(set = 0, binding = 0) readonly buffer ConvOut {
    float conv_out[];
};

layout(set = 0, binding = 1) readonly buffer DtBiasF32 {
    float dt_bias_f32[];
};
layout(set = 0, binding = 1) readonly buffer DtBiasF16 {
    float16_t dt_bias_f16[];
};

layout(set = 0, binding = 2) readonly buffer Alpha {
    float alpha[];
};

layout(set = 0, binding = 3) readonly buffer Beta {
    float beta[];
};

layout(set = 0, binding = 4) readonly buffer SsmAF32 {
    float ssm_a_f32[];
};
layout(set = 0, binding = 4) readonly buffer SsmAF16 {
    float16_t ssm_a_f16[];
};

layout(set = 0, binding = 5) buffer State {
    float state[];
};

layout(set = 0, binding = 6) writeonly buffer Output {
    float out_data[];
};

layout(push_constant) uniform PushConstants {
    uint d_inner;
    uint dt_rank;
    uint head_v_dim;
    uint d_state;
    uint n_group;
    uint ssm_a_is_f16;
    uint dt_bias_is_f16;
    uint has_dt_bias;
    uint has_ssm_a;
    uint n_tok;
    uint conv_stride_tok;
    uint ab_stride_tok;
    uint y_stride_tok;
};

const uint LANES_PER_ROW = 8u;
const uint ROWS_PER_WG = 8u;
const uint COLS_PER_LANE = 16u;

void main() {
    uint h = gl_WorkGroupID.x;
    uint row_block = gl_WorkGroupID.y;
    uint tid = gl_LocalInvocationID.x;
    uint lane = tid % LANES_PER_ROW;
    uint row_slot = tid / LANES_PER_ROW;
    uint row = row_block * ROWS_PER_WG + row_slot;

    if (h >= dt_rank || row >= head_v_dim) return;

    uint qk_dim = d_state * n_group;
    uint k_hi = (n_group == dt_rank) ? h : (h % n_group);
    uint q_base0 = k_hi * d_state;
    uint k_base0 = qk_dim + q_base0;

    uint s_base = h * head_v_dim * head_v_dim;
    uint row_base = s_base + row * head_v_dim;

    float reg_state[COLS_PER_LANE];
    [[unroll]] for (uint r = 0u; r < COLS_PER_LANE; r++) {
        uint col = r * LANES_PER_ROW + lane;
        reg_state[r] = state[row_base + col];
    }

    float dt_bias_val = 0.0;
    if (has_dt_bias != 0) {
        dt_bias_val = (dt_bias_is_f16 != 0) ? float(dt_bias_f16[h]) : dt_bias_f32[h];
    }
    float ssm_a_val = 0.0;
    if (has_ssm_a != 0) {
        ssm_a_val = (ssm_a_is_f16 != 0) ? float(ssm_a_f16[h]) : ssm_a_f32[h];
    }

    for (uint t = 0u; t < n_tok; t++) {
        uint conv_base = t * conv_stride_tok;
        uint ab_base = t * ab_stride_tok;
        uint y_base = t * y_stride_tok;
        uint q_base = conv_base + q_base0;
        uint k_base = conv_base + k_base0;
        uint v_offset = conv_base + 2u * qk_dim + h * head_v_dim;

        float gate_bcast = 0.0;
        float beta_bcast = 0.0;
        if (gl_SubgroupInvocationID == 0u) {
            float a = alpha[ab_base + h] + dt_bias_val;
            float sp = log(1.0 + exp(a));
            float gate_val = (has_ssm_a != 0) ? (sp * ssm_a_val) : -sp;
            gate_bcast = exp(gate_val);
            beta_bcast = 1.0 / (1.0 + exp(-beta[ab_base + h]));
        }

        float g_val = subgroupBroadcastFirst(gate_bcast);
        float b_val = subgroupBroadcastFirst(beta_bcast);
        float v_val = conv_out[v_offset + row];

        float sk = 0.0;
        [[unroll]] for (uint r = 0u; r < COLS_PER_LANE; r++) {
            uint col = r * LANES_PER_ROW + lane;
            float k_val = conv_out[k_base + col];
            reg_state[r] *= g_val;
            sk += reg_state[r] * k_val;
        }
        sk = subgroupClusteredAdd(sk, 8u);

        float d_val = b_val * (v_val - sk);

        float o_val = 0.0;
        [[unroll]] for (uint r = 0u; r < COLS_PER_LANE; r++) {
            uint col = r * LANES_PER_ROW + lane;
            float k_val = conv_out[k_base + col];
            float q_val = conv_out[q_base + col];
            reg_state[r] += k_val * d_val;
            o_val += reg_state[r] * q_val;
        }
        o_val = subgroupClusteredAdd(o_val, 8u);

        if (lane == 0u) {
            out_data[y_base + h * head_v_dim + row] = o_val;
        }
    }

    [[unroll]] for (uint r = 0u; r < COLS_PER_LANE; r++) {
        uint col = r * LANES_PER_ROW + lane;
        state[row_base + col] = reg_state[r];
    }
}
