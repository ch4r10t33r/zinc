---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { buildBreadcrumbList } from '../../lib/structured-data';
import rocmReference from '../../data/llama-rocm-reference.json';
import benchmarkData from '../../data/zinc-performance.json';

interface Props {
  pagePath?: string;
  canonicalPath?: string;
}

const {
  pagePath = '/zinc/benchmarks',
  canonicalPath = '/zinc/benchmarks',
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://zolotukhin.ai';
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const pageUrl = `${siteUrl}${pagePath}`;
const githubRepoUrl = 'https://github.com/zolotukhin/zinc';
const breadcrumbItems = [
  { name: 'Home', href: '/' },
  { name: 'ZINC', href: '/zinc/' },
  { name: 'Benchmarks' },
];

const scenarioOrder = ['core', 'context-medium', 'context-long', 'decode-extended'];
const hiddenBenchmarkModels = new Set<string>();
const scenarioMeta: Record<string, { label: string; short: string; eyebrow: string; description: string }> = {
  core: {
    label: 'Quick Chat',
    short: 'Quick',
    eyebrow: 'Chat',
    description: 'A short assistant turn with enough decode budget to avoid one-token screenshot rates.',
  },
  'context-medium': {
    label: 'Coding Review',
    short: 'Coding',
    eyebrow: 'Code',
    description: 'A small TypeScript review task that asks for the bug, cause, and corrected implementation.',
  },
  'context-long': {
    label: 'Incident Context',
    short: 'Context',
    eyebrow: 'Support',
    description: 'A support-style incident packet that exposes prefill behavior and prompt+decode latency.',
  },
  'decode-extended': {
    label: 'Long Coding Draft',
    short: 'Long draft',
    eyebrow: 'Generation',
    description: 'A longer engineering-plan generation task that stresses sustained decode.',
  },
};

function metricValue(summary: any) {
  return summary?.median ?? summary?.avg ?? null;
}

function hasValue(value: number | null | undefined) {
  return value != null && !Number.isNaN(value);
}

function formatNumber(value: number | null | undefined, digits = 1) {
  if (value == null || Number.isNaN(value)) return 'n/a';
  return value.toFixed(digits);
}

function formatMetric(value: number | null | undefined, suffix: string, digits = 1) {
  if (value == null || Number.isNaN(value)) return 'n/a';
  return `${value.toFixed(digits)} ${suffix}`;
}

function formatMetricSpread(
  value: number | null | undefined,
  spread: number | null | undefined,
  suffix: string,
  digits = 1,
) {
  if (value == null || Number.isNaN(value)) return 'n/a';
  const spreadText = spread != null && !Number.isNaN(spread) ? ` +/- ${spread.toFixed(digits)}` : '';
  return `${value.toFixed(digits)}${spreadText} ${suffix}`;
}

function formatPercent(value: number | null | undefined, digits = 0) {
  if (value == null || Number.isNaN(value)) return 'n/a';
  return `${value.toFixed(digits)}%`;
}

function formatDate(iso: string | null | undefined) {
  if (!iso) return 'unknown';
  return new Intl.DateTimeFormat('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    hour: 'numeric',
    minute: '2-digit',
  }).format(new Date(iso));
}

function formatShortDate(iso: string | null | undefined) {
  if (!iso) return 'n/a';
  return new Intl.DateTimeFormat('en-US', {
    month: 'short',
    day: 'numeric',
  }).format(new Date(iso));
}

function formatUtcShortDate(iso: string | null | undefined) {
  if (!iso) return 'n/a';
  return new Intl.DateTimeFormat('en-US', {
    month: 'short',
    day: 'numeric',
    timeZone: 'UTC',
  }).format(new Date(iso));
}

function formatCommit(value: string | null | undefined, digits = 12) {
  if (!value) return 'n/a';
  return value.length > digits ? value.slice(0, digits) : value;
}

function mean(values: Array<number | null | undefined>) {
  const xs = values.filter((value): value is number => value != null && !Number.isNaN(value));
  if (!xs.length) return null;
  return xs.reduce((sum, value) => sum + value, 0) / xs.length;
}

function meterWidth(value: number | null | undefined) {
  if (value == null || Number.isNaN(value) || value <= 0) return 0;
  return Math.max(6, Math.min(100, value));
}

function barWidth(value: number | null | undefined, maxValue: number | null | undefined) {
  if (!hasValue(value) || !hasValue(maxValue) || (maxValue ?? 0) <= 0) return 0;
  return Math.max(3, Math.min(100, ((value ?? 0) / (maxValue ?? 1)) * 100));
}

function maxMetric<T>(items: T[], getter: (item: T) => number | null | undefined) {
  const values = items.map(getter).filter((value): value is number => hasValue(value));
  if (!values.length) return null;
  return Math.max(...values);
}

function ensureScenarios(model: any) {
  if (Array.isArray(model.scenarios) && model.scenarios.length > 0) return model.scenarios;
  return [{
    id: 'core',
    label: 'Quick Answer',
    short_label: 'Quick',
    prompt_mode: model.prompt_mode,
    prompt: model.prompt,
    max_tokens: model.max_tokens,
    notes: model.notes ?? [],
    zinc: model.zinc,
    baseline: model.baseline,
    comparison: model.comparison,
  }];
}

function scenarioForModel(model: any, scenarioId: string) {
  return ensureScenarios(model).find((scenario: any) => scenario.id === scenarioId) ?? null;
}

function scenarioDisplayForTarget(target: any, scenarioId: string) {
  for (const model of target.models ?? []) {
    const scenario = scenarioForModel(model, scenarioId);
    if (scenario) {
      return {
        label: scenario.label ?? scenarioMeta[scenarioId]?.label ?? scenarioId,
        short: scenario.short_label ?? scenarioMeta[scenarioId]?.short ?? scenarioId,
        description: scenario.notes?.[0] ?? scenarioMeta[scenarioId]?.description ?? '',
      };
    }
  }
  return {
    label: scenarioMeta[scenarioId]?.label ?? scenarioId,
    short: scenarioMeta[scenarioId]?.short ?? scenarioId,
    description: scenarioMeta[scenarioId]?.description ?? '',
  };
}

function decodeValue(scenario: any) {
  return metricValue(scenario?.zinc?.decode_tps);
}

function baselineDecodeValue(scenario: any) {
  return metricValue(scenario?.baseline?.decode_tps);
}

function promptValue(scenario: any) {
  return metricValue(scenario?.zinc?.prefill_tps);
}

function baselinePromptValue(scenario: any) {
  return metricValue(scenario?.baseline?.prefill_tps);
}

function promptTokensValue(scenario: any) {
  return scenario?.zinc?.prompt_tokens ?? scenario?.baseline?.prompt_tokens ?? null;
}

function generatedTokensValue(scenario: any) {
  return scenario?.zinc?.generated_tokens ?? scenario?.baseline?.generated_tokens ?? scenario?.max_tokens ?? null;
}

function zincPromptTokensValue(scenario: any) {
  return scenario?.zinc?.prompt_tokens ?? null;
}

function baselinePromptTokensValue(scenario: any) {
  return scenario?.baseline?.prompt_tokens ?? null;
}

function zincGeneratedTokensValue(scenario: any) {
  return scenario?.zinc?.generated_tokens ?? null;
}

function baselineGeneratedTokensValue(scenario: any) {
  return scenario?.baseline?.generated_tokens ?? null;
}

function tokenShapeText(scenario: any, compact = false) {
  const promptTokens = promptTokensValue(scenario);
  const generatedTokens = generatedTokensValue(scenario);
  const capTokens = scenario?.max_tokens ?? null;
  const promptLabel = compact ? `${formatNumber(promptTokens, 0)}p` : formatMetric(promptTokens, 'tok prompt', 0);
  const outputLabel = compact ? `${formatNumber(generatedTokens, 0)}out` : formatMetric(generatedTokens, 'tok output', 0);

  if (hasValue(generatedTokens) && hasValue(capTokens) && generatedTokens !== capTokens) {
    const capLabel = compact ? `${formatNumber(capTokens, 0)}cap` : formatMetric(capTokens, 'tok cap', 0);
    return `${promptLabel} · ${outputLabel}/${capLabel}`;
  }

  if (hasValue(generatedTokens)) return `${promptLabel} · ${outputLabel}`;
  if (hasValue(capTokens)) return `${promptLabel} · ${compact ? `${formatNumber(capTokens, 0)}cap` : formatMetric(capTokens, 'tok cap', 0)}`;
  return promptLabel;
}

function prefillMsValue(scenario: any) {
  return metricValue(scenario?.zinc?.prefill_ms);
}

function totalLatencyValue(scenario: any) {
  return metricValue(scenario?.zinc?.total_latency_ms);
}

function baselineTotalLatencyValue(scenario: any) {
  return metricValue(scenario?.baseline?.total_latency_ms);
}

function endToEndValue(scenario: any) {
  return metricValue(scenario?.zinc?.end_to_end_tps);
}

function baselineEndToEndValue(scenario: any) {
  return metricValue(scenario?.baseline?.end_to_end_tps);
}

function promptRatioValue(scenario: any) {
  return scenario?.comparison?.prompt_pct_of_baseline ?? null;
}

function decodeRatioValue(scenario: any) {
  return scenario?.comparison?.pct_of_baseline ?? null;
}

function promptDeltaValue(scenario: any) {
  const zincPrompt = promptValue(scenario);
  const baselinePrompt = baselinePromptValue(scenario);
  if (!hasValue(zincPrompt) || !hasValue(baselinePrompt)) return null;
  return zincPrompt - baselinePrompt;
}

function decodeDeltaValue(scenario: any) {
  return scenario?.comparison?.delta_tps ?? null;
}

function latencyDeltaValue(scenario: any) {
  return scenario?.comparison?.latency_delta_ms ?? null;
}

function endToEndRatioValue(scenario: any) {
  return scenario?.comparison?.end_to_end_pct_of_baseline ?? null;
}

function endToEndDeltaValue(scenario: any) {
  return scenario?.comparison?.end_to_end_delta_tps ?? null;
}

function combinedPhaseSeconds(
  prefillTps: number | null | undefined,
  decodeTps: number | null | undefined,
  promptTokens: number | null | undefined,
  generatedTokens: number | null | undefined,
) {
  const prompt = promptTokens ?? 0;
  const generated = generatedTokens ?? 0;
  if (prompt <= 0 && generated <= 0) return null;

  let seconds = 0;
  if (prompt > 0) {
    if (!hasValue(prefillTps) || (prefillTps ?? 0) <= 0) return null;
    seconds += prompt / (prefillTps ?? 1);
  }
  if (generated > 0) {
    if (!hasValue(decodeTps) || (decodeTps ?? 0) <= 0) return null;
    seconds += generated / (decodeTps ?? 1);
  }
  return seconds > 0 ? seconds : null;
}

function combinedPhaseThroughput(
  prefillTps: number | null | undefined,
  decodeTps: number | null | undefined,
  promptTokens: number | null | undefined,
  generatedTokens: number | null | undefined,
) {
  const seconds = combinedPhaseSeconds(prefillTps, decodeTps, promptTokens, generatedTokens);
  if (!hasValue(seconds) || (seconds ?? 0) <= 0) return null;
  return ((promptTokens ?? 0) + (generatedTokens ?? 0)) / (seconds ?? 1);
}

function matchingGeneratedBudget(scenario: any) {
  const zincGenerated = zincGeneratedTokensValue(scenario);
  const baselineGenerated = baselineGeneratedTokensValue(scenario);
  if (!hasValue(zincGenerated) || !hasValue(baselineGenerated)) return false;
  if (zincGenerated !== baselineGenerated) return false;
  const expected = scenario?.max_tokens ?? null;
  if (hasValue(expected) && (zincGenerated ?? 0) < (expected ?? 0)) return false;
  return true;
}

function overallValue(scenario: any) {
  return combinedPhaseThroughput(
    promptValue(scenario),
    decodeValue(scenario),
    zincPromptTokensValue(scenario),
    zincGeneratedTokensValue(scenario),
  ) ?? endToEndValue(scenario);
}

function baselineOverallValue(scenario: any) {
  return combinedPhaseThroughput(
    baselinePromptValue(scenario),
    baselineDecodeValue(scenario),
    baselinePromptTokensValue(scenario),
    baselineGeneratedTokensValue(scenario),
  ) ?? baselineEndToEndValue(scenario);
}

function computedOverallRatioValue(scenario: any) {
  if (!matchingGeneratedBudget(scenario)) return null;
  const zincSeconds = combinedPhaseSeconds(
    promptValue(scenario),
    decodeValue(scenario),
    zincPromptTokensValue(scenario),
    zincGeneratedTokensValue(scenario),
  );
  const baselineSeconds = combinedPhaseSeconds(
    baselinePromptValue(scenario),
    baselineDecodeValue(scenario),
    baselinePromptTokensValue(scenario),
    baselineGeneratedTokensValue(scenario),
  );
  if (hasValue(zincSeconds) && hasValue(baselineSeconds) && (zincSeconds ?? 0) > 0) {
    return ((baselineSeconds ?? 0) / (zincSeconds ?? 1)) * 100;
  }
  return null;
}

function overallRatioValue(scenario: any) {
  const computed = computedOverallRatioValue(scenario);
  if (hasValue(computed)) return computed;

  if (
    scenario?.comparison?.overall_basis === 'phase_wall_time_v2'
    && scenario?.comparison?.overall_comparable
    && hasValue(scenario?.comparison?.overall_pct_of_baseline)
  ) {
    return scenario.comparison.overall_pct_of_baseline;
  }

  if (matchingGeneratedBudget(scenario) && hasValue(endToEndRatioValue(scenario))) return endToEndRatioValue(scenario);
  return null;
}

function overallDeltaValue(scenario: any) {
  if (hasValue(overallRatioValue(scenario)) && hasValue(scenario?.comparison?.overall_delta_tps)) {
    return scenario.comparison.overall_delta_tps;
  }
  const zinc = overallValue(scenario);
  const baseline = baselineOverallValue(scenario);
  if (!hasValue(zinc) || !hasValue(baseline)) return null;
  return (zinc ?? 0) - (baseline ?? 0);
}

function aggregateOverallRatio(scenarios: any[]) {
  let zincSeconds = 0;
  let baselineSeconds = 0;
  let count = 0;
  for (const scenario of scenarios) {
    if (!matchingGeneratedBudget(scenario)) continue;
    const zinc = combinedPhaseSeconds(
      promptValue(scenario),
      decodeValue(scenario),
      zincPromptTokensValue(scenario),
      zincGeneratedTokensValue(scenario),
    );
    const baseline = combinedPhaseSeconds(
      baselinePromptValue(scenario),
      baselineDecodeValue(scenario),
      baselinePromptTokensValue(scenario),
      baselineGeneratedTokensValue(scenario),
    );
    if (!hasValue(zinc) || !hasValue(baseline) || (zinc ?? 0) <= 0 || (baseline ?? 0) <= 0) continue;
    zincSeconds += zinc ?? 0;
    baselineSeconds += baseline ?? 0;
    count += 1;
  }
  return count > 0 && zincSeconds > 0 ? (baselineSeconds / zincSeconds) * 100 : null;
}

function ratioTone(value: number | null | undefined) {
  if (value == null || Number.isNaN(value)) return 'neutral';
  if (value >= 90) return 'positive';
  if (value >= 50) return 'caution';
  return 'negative';
}

function warningText(scenario: any) {
  return scenario?.zinc?.unavailable_reason ?? scenario?.baseline?.unavailable_reason ?? null;
}

function compactReason(reason: string | null | undefined) {
  if (!reason) return null;
  if (reason.startsWith('ZINC run failed:')) return 'ZINC benchmark run failed on this target.';
  if (reason.startsWith('RDNA baseline failed:') || reason.startsWith('Local baseline failed:')) {
    return 'llama.cpp baseline collection failed for this model.';
  }
  if (reason.includes('No local llama-server or llama-cli binary found')) return 'llama.cpp baseline is not configured on this machine.';
  if (reason.length > 120) return `${reason.slice(0, 117)}...`;
  return reason;
}

function outputQualityStatus(scenario: any) {
  const preview = `${scenario?.zinc?.output_preview ?? ''}`.trim();
  const generatedTokens = scenario?.zinc?.generated_tokens ?? null;
  if (!preview) {
    return {
      tone: 'neutral',
      label: 'No Preview',
      note: 'No output preview was captured for this workload.',
    };
  }

  if (/^<\|(?:im_end|endoftext|end)\|>$/.test(preview) || (generatedTokens != null && generatedTokens <= 4 && preview.includes('<|im_end|>'))) {
    return {
      tone: 'caution',
      label: 'Preview flagged',
      note: 'ZINC completed numerically, but the preview is only a stop token.',
    };
  }

  if (/(?:^|[\s:])(?:\d+\.){12,}/.test(preview)) {
    return {
      tone: 'caution',
      label: 'Preview flagged',
      note: 'ZINC completed numerically, but the preview shows a repeated numeric pattern.',
    };
  }

  return {
    tone: 'positive',
    label: 'Preview OK',
    note: 'The captured preview does not show an obvious stop-token or repetition failure.',
  };
}

function isReviewOutputScenario(scenario: any) {
  return outputQualityStatus(scenario).tone === 'caution';
}

function scenarioStatus(scenario: any) {
  const zincOk = promptValue(scenario) != null || decodeValue(scenario) != null || endToEndValue(scenario) != null;
  const baselineOk = baselinePromptValue(scenario) != null || baselineDecodeValue(scenario) != null;
  const reason = compactReason(warningText(scenario));

  if (zincOk && baselineOk) {
    return {
      tone: 'positive',
      label: 'Compared',
      note: 'ZINC and llama.cpp both completed this workload.',
    };
  }

  if (zincOk) {
    return {
      tone: 'caution',
      label: 'ZINC Only',
      note: reason ?? 'Baseline is unavailable for this model on this target.',
    };
  }

  return {
    tone: 'negative',
    label: 'Run Failed',
    note: reason ?? 'No benchmark result recorded for this model.',
  };
}

function normalizeTarget(target: any) {
  const visibleModels = [...(target.models ?? [])]
    .filter((model: any) => !hiddenBenchmarkModels.has(model.id))
    .map((model: any) => ({
      ...model,
      scenarios: ensureScenarios(model),
    }));

  const successful = visibleModels.filter((model: any) => model?.zinc?.decode_tps);
  const allScenarios = visibleModels.flatMap((model: any) => ensureScenarios(model));
  const summaryScenarios = allScenarios.filter((scenario: any) => !isReviewOutputScenario(scenario));
  const compared = visibleModels.filter((model: any) => ensureScenarios(model).some((scenario: any) => !isReviewOutputScenario(scenario) && overallRatioValue(scenario) != null));
  const fastest = successful.length > 0
    ? [...successful].sort((a, b) => (b.zinc.decode_tps.median ?? b.zinc.decode_tps.avg ?? 0) - (a.zinc.decode_tps.median ?? a.zinc.decode_tps.avg ?? 0))[0]
    : null;

  return {
    ...target,
    models: visibleModels,
    summary: {
      ...(target.summary ?? {}),
      fastest_model_id: fastest?.id ?? null,
      fastest_model_label: fastest?.label ?? null,
      fastest_decode_tps: fastest ? (fastest.zinc.decode_tps.median ?? fastest.zinc.decode_tps.avg ?? null) : null,
      benchmarked_models: visibleModels.length,
      successful_models: successful.length,
      compared_models: compared.length,
      average_decode_tps: mean(successful.map((model: any) => model.zinc.decode_tps.median ?? model.zinc.decode_tps.avg ?? null)),
      average_prompt_tps: mean(successful.map((model: any) => model.zinc.prefill_tps?.median ?? model.zinc.prefill_tps?.avg ?? null)),
      average_pct_of_llama: aggregateOverallRatio(summaryScenarios),
    },
  };
}

function scenarioIdsForTarget(target: any) {
  const ids = new Set<string>();
  for (const model of target.models) {
    for (const scenario of ensureScenarios(model)) ids.add(scenario.id);
  }
  return scenarioOrder.filter((id) => ids.has(id));
}

const targetOrder = ['rdna', 'metal', 'intel'];
function targetRank(id: string) {
  const index = targetOrder.indexOf(id);
  return index === -1 ? targetOrder.length : index;
}

const targets = [...benchmarkData.targets]
  .sort((a, b) => targetRank(a.id) - targetRank(b.id))
  .map(normalizeTarget);

const totalUniqueModels = new Set(targets.flatMap((target) => target.models.map((model: any) => model.id))).size;
const totalComparedModels = targets.reduce((sum, target) => sum + (target.summary?.compared_models ?? 0), 0);

function benchmarkedCount(target: any) {
  return target.summary?.benchmarked_models ?? target.models.length ?? 0;
}

function successfulCount(target: any) {
  return target.summary?.successful_models ?? 0;
}

function failedCount(target: any) {
  return Math.max(0, benchmarkedCount(target) - successfulCount(target));
}

function isPartialTarget(target: any) {
  return failedCount(target) > 0;
}

function sampleCount(summary: any) {
  return summary?.samples?.length ?? 0;
}

function formatSignedMetric(value: number | null | undefined, suffix: string, digits = 1) {
  if (value == null || Number.isNaN(value)) return 'n/a';
  const sign = value > 0 ? '+' : '';
  return `${sign}${value.toFixed(digits)} ${suffix}`;
}

function formatLatencyDelta(value: number | null | undefined) {
  if (value == null || Number.isNaN(value)) return 'n/a';
  const rounded = Math.abs(value) >= 100 ? 0 : 1;
  const amount = Math.abs(value).toFixed(rounded);
  return value > 0 ? `${amount} ms slower` : `${amount} ms faster`;
}

function formatRuns(runs: number | null | undefined, warmupRuns: number | null | undefined) {
  if (runs == null && warmupRuns == null) return 'n/a';
  return `${runs ?? 0} measured · ${warmupRuns ?? 0} warmup`;
}

function githubBlobUrl(ref: string | null | undefined, filePath: string, startLine?: number, endLine?: number) {
  const revision = ref || 'main';
  const lineAnchor = startLine == null
    ? ''
    : endLine == null || endLine === startLine
      ? `#L${startLine}`
      : `#L${startLine}-L${endLine}`;
  return `${githubRepoUrl}/blob/${revision}/${filePath}${lineAnchor}`;
}

function displayModelLabel(modelOrLabel: any) {
  const label = typeof modelOrLabel === 'string'
    ? modelOrLabel
    : (modelOrLabel?.label ?? modelOrLabel?.id ?? 'n/a');
  return label
    .replace(/^Gemma4\b/i, 'Gemma 4')
    .replace(/^Qwen36\b/i, 'Qwen 3.6')
    .replace(/^Qwen3\b/i, 'Qwen 3')
    .replace(/\bQ4_K_XL\b/g, 'Q4K XL')
    .replace(/\bQ4_K_M\b/g, 'Q4K M');
}

function normalizedModelName(model: any) {
  return displayModelLabel(model)
    .toLowerCase()
    .replace(/\bgemma4\b/g, 'gemma 4')
    .replace(/\bqwen36\b/g, 'qwen 3.6')
    .replace(/\bqwen3\b/g, 'qwen 3')
    .replace(/q4_k/g, 'q4k')
    .replace(/[_-]+/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}
function compareModels(a: any, b: any) {
  return normalizedModelName(a).localeCompare(normalizedModelName(b), undefined, {
    numeric: true,
    sensitivity: 'base',
  });
}

const rocmRows = [...(rocmReference.rows ?? [])].sort(compareModels);
const rocmDepthRows = rocmReference.qwen35_depth_sweep ?? [];
const rocmAvgPrefill = mean(rocmRows.map((row: any) => row.prefill_tps));
const rocmAvgDecode = mean(rocmRows.map((row: any) => row.decode_tps));
const rocmMaxPrefill = maxMetric(rocmRows, (row: any) => row.prefill_tps);
const rocmMaxDecode = maxMetric(rocmRows, (row: any) => row.decode_tps);
const rocmFastestPrefill = rocmRows.length > 0
  ? [...rocmRows].sort((a: any, b: any) => (b.prefill_tps ?? 0) - (a.prefill_tps ?? 0))[0]
  : null;
const rocmFastestDecode = rocmRows.length > 0
  ? [...rocmRows].sort((a: any, b: any) => (b.decode_tps ?? 0) - (a.decode_tps ?? 0))[0]
  : null;

function scenarioRows(target: any, scenarioId: string) {
  return [...target.models]
    .map((model: any) => ({
      model,
      scenario: scenarioForModel(model, scenarioId),
    }))
    .filter((row) => row.scenario != null)
    .sort((a, b) => compareModels(a.model, b.model));
}

function scenarioSummary(target: any, scenarioId: string) {
  const rows = scenarioRows(target, scenarioId);
  const summaryRows = rows.filter((row) => !isReviewOutputScenario(row.scenario));
  const comparedRows = summaryRows.filter((row) => overallRatioValue(row.scenario) != null);
  const summaryScenarios = summaryRows.map((row) => row.scenario);
  const fastestRow = summaryRows.length > 0
    ? [...summaryRows].sort((a, b) => (decodeValue(b.scenario) ?? -1) - (decodeValue(a.scenario) ?? -1))[0]
    : null;
  const closestRow = comparedRows.length > 0
    ? [...comparedRows].sort((a, b) => (overallRatioValue(b.scenario) ?? 0) - (overallRatioValue(a.scenario) ?? 0))[0]
    : null;
  return {
    count: rows.length,
    comparedCount: comparedRows.length,
    avgPrompt: mean(summaryRows.map((row) => promptValue(row.scenario))),
    avgDecode: mean(summaryRows.map((row) => decodeValue(row.scenario))),
    avgEndToEnd: mean(summaryRows.map((row) => endToEndValue(row.scenario))),
    avgLatency: mean(summaryRows.map((row) => totalLatencyValue(row.scenario))),
    avgPromptTokens: mean(summaryRows.map((row) => promptTokensValue(row.scenario))),
    avgPrefillMs: mean(summaryRows.map((row) => prefillMsValue(row.scenario))),
    avgPromptGap: mean(summaryRows.map((row) => promptRatioValue(row.scenario))),
    avgDecodeGap: mean(summaryRows.map((row) => decodeRatioValue(row.scenario))),
    avgOverall: mean(summaryRows.map((row) => overallValue(row.scenario))),
    avgOverallGap: aggregateOverallRatio(summaryScenarios),
    reviewCount: rows.filter((row) => isReviewOutputScenario(row.scenario)).length,
    fastestModelLabel: fastestRow?.model?.label ?? null,
    fastestDecode: fastestRow ? decodeValue(fastestRow.scenario) : null,
    closestModelLabel: closestRow?.model?.label ?? null,
    closestRatio: closestRow ? overallRatioValue(closestRow.scenario) : null,
  };
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      name: 'ZINC Benchmarks vs llama.cpp',
      description: 'ZINC benchmark dashboard for AMD RDNA, Intel Arc, and Apple Silicon, including prompt throughput, prefill latency, decode throughput, total latency, same-machine comparison against llama.cpp, and a separate llama.cpp ROCm reference sweep.',
      url: pageUrl,
      about: {
        '@type': 'SoftwareApplication',
        name: 'ZINC',
        applicationCategory: 'DeveloperApplication',
        operatingSystem: 'Linux, macOS',
        codeRepository: 'https://github.com/zolotukhin/zinc',
      },
      keywords: 'ZINC benchmarks, llama.cpp comparison, llama.cpp ROCm benchmark, Apple Silicon Metal benchmark, AMD RDNA benchmark, Intel Arc benchmark, local LLM benchmark, prefill throughput, decode throughput, latency benchmark',
    },
    {
      '@type': 'Dataset',
      name: 'ZINC benchmark artifact',
      description: 'Structured benchmark artifact used to render the public ZINC benchmarks dashboard across RDNA, Intel Arc, and Metal targets.',
      dateModified: benchmarkData.generated_at,
      distribution: {
        '@type': 'DataDownload',
        encodingFormat: 'application/json',
        contentUrl: canonicalUrl,
      },
    },
    {
      '@type': 'Dataset',
      name: rocmReference.label,
      description: rocmReference.description,
      dateModified: rocmReference.generated_at,
      measurementTechnique: rocmReference.methodology.tool,
      variableMeasured: ['llama.cpp ROCm prefill throughput', 'llama.cpp ROCm decode throughput'],
    },
    buildBreadcrumbList(siteUrl, breadcrumbItems),
  ],
};
---

<BaseLayout
  title="ZINC Benchmarks vs llama.cpp"
  description="ZINC benchmark dashboard for AMD RDNA, Intel Arc, and Apple Silicon, with scenario-based prompt throughput, decode throughput, same-machine comparison against llama.cpp, and a separate llama.cpp ROCm reference sweep."
  keywords="ZINC benchmarks, llama.cpp comparison, llama.cpp ROCm benchmark, Apple Silicon Metal benchmark, AMD RDNA benchmark, Intel Arc benchmark, local LLM benchmark, prefill throughput, decode throughput, latency benchmark"
  canonicalUrl={canonicalUrl}
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} />

  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">ZINC</p>
      <h1>Benchmarks</h1>
      <p class="intro">ZINC vs llama.cpp on the same machines, plus a separate ROCm reference for llama.cpp on AMD.</p>
    </div>
    <div class="hero-stats">
      <article class="stat-card">
        <span>Targets</span>
        <strong>{targets.length}</strong>
      </article>
      <article class="stat-card">
        <span>Unique Models</span>
        <strong>{totalUniqueModels}</strong>
      </article>
      <article class="stat-card">
        <span>Comparisons</span>
        <strong>{totalComparedModels}</strong>
      </article>
      <article class="stat-card">
        <span>Updated</span>
        <strong>{formatShortDate(benchmarkData.generated_at)}</strong>
      </article>
    </div>
  </section>

  <nav class="target-tabs" aria-label="Benchmark targets" role="tablist">
    {targets.map((target, index) => (
      <button
        type="button"
        role="tab"
        id={`tab-${target.id}`}
        aria-controls={`panel-${target.id}`}
        aria-selected={index === 0 ? 'true' : 'false'}
        class:list={['target-tab', { active: index === 0 }]}
        data-bench-target-tab={target.id}
      >
        <div class="target-tab-head">
          <span>
            {target.label}
            {isPartialTarget(target) && <em>partial</em>}
          </span>
          <small>{target.machine.gpu}</small>
        </div>
        <div class="target-tab-stats">
          <div>
            <strong>{formatNumber(target.summary?.average_decode_tps)}</strong>
            <small>tok/s</small>
          </div>
          <div>
            <strong>{formatPercent(target.summary?.average_pct_of_llama)}</strong>
            <small>overall</small>
          </div>
          <div>
            <strong>{successfulCount(target)}/{benchmarkedCount(target)}</strong>
            <small>complete</small>
          </div>
        </div>
      </button>
    ))}
  </nav>

  {targets.map((target, index) => {
    const scenarioIds = scenarioIdsForTarget(target);
    const defaultScenario = scenarioIds[0] ?? 'core';
    const provenance = target.provenance ?? {};
    const zincProvenance = provenance.zinc ?? {};
    const llamaCppProvenance = provenance.llama_cpp ?? {};
    const sourceRef = zincProvenance.commit ?? 'main';
    const suiteSourceHref = githubBlobUrl(sourceRef, 'tools/performance_suite.mjs');
    const promptSourceHref = githubBlobUrl(sourceRef, 'tools/performance_suite.mjs', 1502, 1640);
    const promptTestHref = githubBlobUrl(sourceRef, 'tools/performance_suite.test.ts', 223, 238);
    const dataSourceHref = githubBlobUrl('main', 'site/src/data/zinc-performance.json');

    return (
      <section
        id={`panel-${target.id}`}
        role="tabpanel"
        aria-labelledby={`tab-${target.id}`}
        class:list={['target-panel', { active: index === 0 }]}
        data-bench-target-panel={target.id}
        data-default-scenario={defaultScenario}
        hidden={index !== 0}
      >
        <header class="panel-header">
          <div>
            <p class="eyebrow">{target.machine.label}</p>
            <h2>{target.label}</h2>
            <p class="panel-copy">{target.machine.gpu} · {target.machine.memory ?? 'n/a'} · {formatRuns(target.methodology?.runs, target.methodology?.warmup_runs)}</p>
            {(target.summary?.successful_models ?? 0) < (target.summary?.benchmarked_models ?? 0) && (
              <p class="panel-banner" role="note">
                <strong>Experimental bring-up.</strong>{' '}
                Only {(target.summary?.successful_models ?? 0)} of {(target.summary?.benchmarked_models ?? 0)} ZINC runs completed on this node in the current artifact ({formatShortDate(target.generated_at)}); the rest currently fail (see each row's status for the underlying reason). Numbers and averages shown reflect only the rows that completed — treat them as a partial signal, not a head-to-head verdict.
              </p>
            )}
          </div>
          <details class="machine-details">
            <summary>Run info</summary>
            <dl class="machine-card">
              <div>
                <dt>GPU</dt>
                <dd>{target.machine.gpu}</dd>
              </div>
              <div>
                <dt>Chip</dt>
                <dd>{target.machine.chip ?? 'n/a'}</dd>
              </div>
              <div>
                <dt>Memory</dt>
                <dd>{target.machine.memory ?? 'n/a'}</dd>
              </div>
              <div>
                <dt>Artifact</dt>
                <dd>{formatDate(target.generated_at)}</dd>
              </div>
              <div>
                <dt>ZINC</dt>
                <dd title={zincProvenance.version ?? zincProvenance.commit ?? 'n/a'}>
                  {zincProvenance.version ?? formatCommit(zincProvenance.commit)}
                </dd>
              </div>
              <div>
                <dt>llama.cpp</dt>
                <dd title={llamaCppProvenance.version ?? llamaCppProvenance.commit ?? 'n/a'}>
                  {llamaCppProvenance.version ?? formatCommit(llamaCppProvenance.commit)}
                </dd>
              </div>
            </dl>
          </details>
        </header>

        <div class="summary-grid">
          <article class="summary-card">
            <span>Fastest</span>
            <strong>{formatMetric(target.summary?.fastest_decode_tps, 'tok/s')}</strong>
            <small>{displayModelLabel(target.summary?.fastest_model_label)}</small>
          </article>
          <article class="summary-card">
            <span>Decode</span>
            <strong>{formatMetric(target.summary?.average_decode_tps, 'tok/s')}</strong>
            <small>average</small>
          </article>
          <article class="summary-card">
            <span>Overall</span>
            <strong>{formatPercent(target.summary?.average_pct_of_llama)}</strong>
            <small>prefill + decode vs llama.cpp</small>
          </article>
        </div>

        <nav class="scenario-tabs" aria-label={`${target.label} scenarios`}>
          {scenarioIds.map((scenarioId, scenarioIndex) => {
            const summary = scenarioSummary(target, scenarioId);
            const scenarioDisplay = scenarioDisplayForTarget(target, scenarioId);
            return (
              <button
                type="button"
                class:list={['scenario-tab', { active: scenarioIndex === 0 }]}
                data-bench-scenario-target={target.id}
                data-bench-scenario={scenarioId}
                aria-pressed={scenarioIndex === 0 ? 'true' : 'false'}
              >
                <div class="scenario-tab-head">
                  <span>{scenarioDisplay.short}</span>
                </div>
                <div class="scenario-tab-stats">
                  <div>
                    <strong>{formatNumber(summary.avgPrompt)}</strong>
                    <small>prefill</small>
                  </div>
                  <div>
                    <strong>{formatNumber(summary.avgDecode)}</strong>
                    <small>decode</small>
                  </div>
                  <div>
                    <strong>{formatPercent(summary.avgOverallGap)}</strong>
                    <small>overall</small>
                  </div>
                </div>
              </button>
            );
          })}
        </nav>

        {scenarioIds.map((scenarioId, scenarioIndex) => {
          const rows = scenarioRows(target, scenarioId);
          const summary = scenarioSummary(target, scenarioId);
          const scenarioDisplay = scenarioDisplayForTarget(target, scenarioId);
          const promptMax = maxMetric(rows, (row) => Math.max(promptValue(row.scenario) ?? 0, baselinePromptValue(row.scenario) ?? 0));
          const decodeMax = maxMetric(rows, (row) => Math.max(decodeValue(row.scenario) ?? 0, baselineDecodeValue(row.scenario) ?? 0));
          const overallMax = maxMetric(rows, (row) => Math.max(overallValue(row.scenario) ?? 0, baselineOverallValue(row.scenario) ?? 0));

          return (
            <section
              class:list={['scenario-panel', { active: scenarioIndex === 0 }]}
              data-bench-scenario-panel={target.id}
              data-bench-scenario-id={scenarioId}
              hidden={scenarioIndex !== 0}
            >
              <article class="scenario-banner">
                <div>
                  <h3>{scenarioDisplay.label}</h3>
                </div>
                <div class="scenario-highlights">
                  <span class="info-chip">
                    <strong>{summary.count}</strong>
                    rows
                  </span>
                  <span class="info-chip">
                    <strong>{formatMetric(summary.avgPrompt, 'tok/s')}</strong>
                    prefill
                  </span>
                  <span class="info-chip">
                    <strong>{formatMetric(summary.avgDecode, 'tok/s')}</strong>
                    decode
                  </span>
                  <span class="info-chip">
                    <strong>{formatPercent(summary.avgOverallGap)}</strong>
                    overall
                  </span>
                </div>
              </article>

              <div class="scenario-readout" aria-label={`${scenarioDisplay.label} summary`}>
                <article class="readout-card">
                  <span>Decode</span>
                  <strong>{formatMetric(summary.avgDecode, 'tok/s')}</strong>
                  <small>{formatPercent(summary.avgDecodeGap)} decode ratio</small>
                </article>
                <article class="readout-card">
                  <span>Prefill</span>
                  <strong>{formatMetric(summary.avgPrompt, 'tok/s')}</strong>
                  <small>{formatPercent(summary.avgPromptGap)} prefill ratio · {formatMetric(summary.avgPromptTokens, 'prompt tok', 0)}</small>
                </article>
                <article class="readout-card">
                  <span>Fastest</span>
                  <strong>{displayModelLabel(summary.fastestModelLabel)}</strong>
                  <small>{formatMetric(summary.fastestDecode, 'tok/s')}</small>
                </article>
                <article class="readout-card">
                  <span>Overall</span>
                  <strong>{formatPercent(summary.avgOverallGap)}</strong>
                  <small>best row: {displayModelLabel(summary.closestModelLabel)}</small>
                </article>
              </div>

              <article class="board-card">
                <header class="board-head">
                  <div>
                    <h3>Models</h3>
                  </div>
                  <div class="legend">
                    <span><i class="legend-swatch zinc"></i>ZINC</span>
                    <span><i class="legend-swatch baseline"></i>llama.cpp</span>
                  </div>
                </header>

                <div class="decode-rank" aria-label="Model decode comparison">
                  {rows.map((row) => {
                    const zincPrompt = promptValue(row.scenario);
                    const baselinePrompt = baselinePromptValue(row.scenario);
                    const zincDecode = decodeValue(row.scenario);
                    const baselineDecode = baselineDecodeValue(row.scenario);
                    const promptRatio = promptRatioValue(row.scenario);
                    const decodeRatio = decodeRatioValue(row.scenario);
                    const overallRatio = overallRatioValue(row.scenario);
                    const rowStatus = scenarioStatus(row.scenario);

                    return (
                      <article class="rank-row">
                        <div class="rank-model">
                          <div>
                            <strong>{displayModelLabel(row.model)}</strong>
                            <small title={rowStatus.note}>{tokenShapeText(row.scenario, true)}</small>
                            <span class:list={['status-pill', 'rank-status', rowStatus.tone]} title={rowStatus.note}>{rowStatus.label}</span>
                          </div>
                        </div>
                        <div class="rank-bars">
                          <div class="rank-metric-group">
                            <div class="rank-metric-title">
                              <span>Prefill</span>
                              <strong class:list={['ratio-pill', ratioTone(promptRatio)]}>{formatPercent(promptRatio)}</strong>
                            </div>
                            <div class="bar-line">
                              <span>ZINC</span>
                              <div class="bar-track" aria-hidden="true">
                                <i class="bar-fill zinc" style={`width: ${barWidth(zincPrompt, promptMax)}%;`}></i>
                              </div>
                              <strong>{formatMetric(zincPrompt, 'tok/s')}</strong>
                            </div>
                            <div class="bar-line baseline">
                              <span>llama</span>
                              <div class="bar-track" aria-hidden="true">
                                <i class="bar-fill baseline" style={`width: ${barWidth(baselinePrompt, promptMax)}%;`}></i>
                              </div>
                              <strong>{formatMetric(baselinePrompt, 'tok/s')}</strong>
                            </div>
                          </div>
                          <div class="rank-metric-group">
                            <div class="rank-metric-title">
                              <span>Decode</span>
                              <strong class:list={['ratio-pill', ratioTone(decodeRatio)]}>{formatPercent(decodeRatio)}</strong>
                            </div>
                            <div class="bar-line">
                              <span>ZINC</span>
                              <div class="bar-track" aria-hidden="true">
                                <i class="bar-fill zinc" style={`width: ${barWidth(zincDecode, decodeMax)}%;`}></i>
                              </div>
                              <strong>{formatMetric(zincDecode, 'tok/s')}</strong>
                            </div>
                            <div class="bar-line baseline">
                              <span>llama</span>
                              <div class="bar-track" aria-hidden="true">
                                <i class="bar-fill baseline" style={`width: ${barWidth(baselineDecode, decodeMax)}%;`}></i>
                              </div>
                              <strong>{formatMetric(baselineDecode, 'tok/s')}</strong>
                            </div>
                          </div>
                        </div>
                        <div class="rank-ratio">
                          <strong class:list={['ratio-pill', ratioTone(overallRatio)]}>{formatPercent(overallRatio)}</strong>
                          <small>overall</small>
                        </div>
                      </article>
                    );
                  })}
                </div>

                <details class="mobile-detail-details">
                  <summary>
                    <strong>Details</strong>
                  </summary>
                  <div class="mobile-bench-list" aria-label="Detailed benchmark cards">
                    {rows.map((row) => {
                      const zincPrompt = promptValue(row.scenario);
                      const baselinePrompt = baselinePromptValue(row.scenario);
                      const zincDecode = decodeValue(row.scenario);
                      const baselineDecode = baselineDecodeValue(row.scenario);
                      const zincOverall = overallValue(row.scenario);
                      const baselineOverall = baselineOverallValue(row.scenario);
                      const zincLatency = totalLatencyValue(row.scenario);
                      const baselineLatency = baselineTotalLatencyValue(row.scenario);
                      const promptRatio = promptRatioValue(row.scenario);
                      const decodeRatio = decodeRatioValue(row.scenario);
                      const overallRatio = overallRatioValue(row.scenario);
                      const rowStatus = scenarioStatus(row.scenario);

                      return (
                        <article class="mobile-model">
                          <header class="mobile-model-head">
                            <div>
                              <strong>{displayModelLabel(row.model)}</strong>
                              <small>{tokenShapeText(row.scenario)}</small>
                            </div>
                            <span class:list={['status-pill', rowStatus.tone]} title={rowStatus.note}>{rowStatus.label}</span>
                          </header>

                          <div class="mobile-metric">
                            <div class="mobile-metric-head">
                              <span>Prefill</span>
                              <strong class:list={['ratio-pill', ratioTone(promptRatio)]}>{formatPercent(promptRatio)}</strong>
                            </div>
                            <div class="bar-line">
                              <span>ZINC</span>
                              <div class="bar-track" aria-hidden="true">
                                <i class="bar-fill zinc" style={`width: ${barWidth(zincPrompt, promptMax)}%;`}></i>
                              </div>
                              <strong>{formatMetric(zincPrompt, 'tok/s')}</strong>
                            </div>
                            <div class="bar-line baseline">
                              <span>llama</span>
                              <div class="bar-track" aria-hidden="true">
                                <i class="bar-fill baseline" style={`width: ${barWidth(baselinePrompt, promptMax)}%;`}></i>
                              </div>
                              <strong>{formatMetric(baselinePrompt, 'tok/s')}</strong>
                            </div>
                          </div>

                          <div class="mobile-metric">
                            <div class="mobile-metric-head">
                              <span>Decode</span>
                              <strong class:list={['ratio-pill', ratioTone(decodeRatio)]}>{formatPercent(decodeRatio)}</strong>
                            </div>
                            <div class="bar-line">
                              <span>ZINC</span>
                              <div class="bar-track" aria-hidden="true">
                                <i class="bar-fill zinc" style={`width: ${barWidth(zincDecode, decodeMax)}%;`}></i>
                              </div>
                              <strong>{formatMetric(zincDecode, 'tok/s')}</strong>
                            </div>
                            <div class="bar-line baseline">
                              <span>llama</span>
                              <div class="bar-track" aria-hidden="true">
                                <i class="bar-fill baseline" style={`width: ${barWidth(baselineDecode, decodeMax)}%;`}></i>
                              </div>
                              <strong>{formatMetric(baselineDecode, 'tok/s')}</strong>
                            </div>
                          </div>

                          <div class="mobile-metric">
                            <div class="mobile-metric-head">
                              <span>Overall</span>
                              <strong class:list={['ratio-pill', ratioTone(overallRatio)]}>{formatPercent(overallRatio)}</strong>
                            </div>
                            <div class="bar-line">
                              <span>ZINC</span>
                              <div class="bar-track" aria-hidden="true">
                                <i class="bar-fill zinc" style={`width: ${barWidth(zincOverall, overallMax)}%;`}></i>
                              </div>
                              <strong>{formatMetric(zincOverall, 'tok/s')}</strong>
                            </div>
                            <div class="bar-line baseline">
                              <span>llama</span>
                              <div class="bar-track" aria-hidden="true">
                                <i class="bar-fill baseline" style={`width: ${barWidth(baselineOverall, overallMax)}%;`}></i>
                              </div>
                              <strong>{formatMetric(baselineOverall, 'tok/s')}</strong>
                            </div>
                            <small class="latency-note">Prompt+decode. Cold latency: ZINC {formatMetric(zincLatency, 'ms', 0)} · llama.cpp {formatMetric(baselineLatency, 'ms', 0)}</small>
                          </div>
                        </article>
                      );
                    })}
                  </div>
                </details>

                <details class="raw-table-details">
                  <summary>
                    <strong>Raw data</strong>
                  </summary>
                  <div class="table-wrap">
                    <table class="bench-table">
                      <thead>
                        <tr>
                          <th>Model</th>
                          <th>Prefill</th>
                          <th>Decode</th>
                          <th>Overall</th>
                        </tr>
                      </thead>
                      <tbody>
                      {rows.map((row) => {
                        const zincPrompt = promptValue(row.scenario);
                        const baselinePrompt = baselinePromptValue(row.scenario);
                        const zincDecode = decodeValue(row.scenario);
                        const baselineDecode = baselineDecodeValue(row.scenario);
                        const zincOverall = overallValue(row.scenario);
                        const baselineOverall = baselineOverallValue(row.scenario);
                        const zincLatency = totalLatencyValue(row.scenario);
                        const baselineLatency = baselineTotalLatencyValue(row.scenario);
                        const promptRatio = promptRatioValue(row.scenario);
                        const decodeRatio = decodeRatioValue(row.scenario);
                        const overallRatio = overallRatioValue(row.scenario);
                        const runCount = sampleCount(row.scenario?.zinc?.decode_tps) || sampleCount(row.scenario?.baseline?.decode_tps);
                        const rowStatus = scenarioStatus(row.scenario);

                        return (
                          <tr>
                            <th scope="row" class="model-cell">
                              <div class="model-row">
                                <div>
                                  <strong>{displayModelLabel(row.model)}</strong>
                                  <small title={rowStatus.note}>{tokenShapeText(row.scenario)} · {runCount || 0} runs · {rowStatus.label}</small>
                                </div>
                              </div>
                            </th>
                            <td>
                              {hasValue(zincPrompt) || hasValue(baselinePrompt) ? (
                                <div class="metric-stack">
                                  <div class="backend-line">
                                    <span class="backend-pill zinc">Z</span>
                                    <div>
                                      <strong>{formatMetric(zincPrompt, 'tok/s')}</strong>
                                      <small>{formatMetric(prefillMsValue(row.scenario), 'ms')}</small>
                                    </div>
                                  </div>
                                  <div class="backend-line baseline">
                                    <span class="backend-pill baseline">L</span>
                                    <div>
                                      <strong>{formatMetric(baselinePrompt, 'tok/s')}</strong>
                                      <small>{formatMetric(metricValue(row.scenario?.baseline?.prefill_ms), 'ms')}</small>
                                    </div>
                                  </div>
                                  {hasValue(promptRatio) ? (
                                    <div class="metric-footer compact">
                                      <strong class:list={['ratio-pill', ratioTone(promptRatio)]}>{formatPercent(promptRatio)}</strong>
                                      <small>{formatSignedMetric(promptDeltaValue(row.scenario), 'tok/s')}</small>
                                    </div>
                                  ) : (
                                    <div class="metric-missing">
                                      <strong>Comparison unavailable</strong>
                                      <small>Prefill telemetry is missing on one side.</small>
                                    </div>
                                  )}
                                </div>
                              ) : (
                                <div class="metric-missing">
                                  <strong>Telemetry pending</strong>
                                  <small>No prefill metrics were published for this run.</small>
                                </div>
                              )}
                            </td>
                            <td>
                              {hasValue(zincDecode) || hasValue(baselineDecode) ? (
                                <div class="metric-stack">
                                  <div class="backend-line">
                                    <span class="backend-pill zinc">Z</span>
                                    <div>
                                      <strong>{formatMetric(zincDecode, 'tok/s')}</strong>
                                      <small>{formatMetric(metricValue(row.scenario?.zinc?.ms_per_token), 'ms/tok')}</small>
                                    </div>
                                  </div>
                                  <div class="backend-line baseline">
                                    <span class="backend-pill baseline">L</span>
                                    <div>
                                      <strong>{formatMetric(baselineDecode, 'tok/s')}</strong>
                                      <small>{formatMetric(metricValue(row.scenario?.baseline?.ms_per_token), 'ms/tok')}</small>
                                    </div>
                                  </div>
                                  {hasValue(decodeRatio) ? (
                                    <div class="metric-footer compact">
                                      <strong class:list={['ratio-pill', ratioTone(decodeRatio)]}>{formatPercent(decodeRatio)}</strong>
                                      <small>{formatSignedMetric(decodeDeltaValue(row.scenario), 'tok/s')}</small>
                                    </div>
                                  ) : (
                                    <div class="metric-missing">
                                      <strong>Comparison unavailable</strong>
                                      <small>No same-machine decode ratio for this row yet.</small>
                                    </div>
                                  )}
                                </div>
                              ) : (
                                <div class="metric-missing">
                                  <strong>Run missing</strong>
                                  <small>No decode result was published for this row.</small>
                                </div>
                              )}
                            </td>
                            <td>
                              {hasValue(zincOverall) || hasValue(baselineOverall) || hasValue(zincLatency) || hasValue(baselineLatency) ? (
                                <div class="metric-stack">
                                  <div class="backend-line">
                                    <span class="backend-pill zinc">Z</span>
                                    <div>
                                      <strong>{formatMetric(zincOverall, 'tok/s')}</strong>
                                      <small>prompt+decode</small>
                                    </div>
                                  </div>
                                  <div class="backend-line baseline">
                                    <span class="backend-pill baseline">L</span>
                                    <div>
                                      <strong>{formatMetric(baselineOverall, 'tok/s')}</strong>
                                      <small>prompt+decode</small>
                                    </div>
                                  </div>
                                  {hasValue(overallRatio) ? (
                                    <div class="metric-footer compact">
                                      <strong class:list={['ratio-pill', ratioTone(overallRatio)]}>{formatPercent(overallRatio)}</strong>
                                      <small>{formatSignedMetric(overallDeltaValue(row.scenario), 'tok/s')}</small>
                                      <small>{formatLatencyDelta(latencyDeltaValue(row.scenario))}</small>
                                    </div>
                                  ) : (
                                    <div class="metric-missing">
                                      <strong>Directional only</strong>
                                      <small>No end-to-end comparison for this row.</small>
                                    </div>
                                  )}
                                </div>
                              ) : (
                                <div class="metric-missing">
                                  <strong>Telemetry pending</strong>
                                  <small>No end-to-end or latency metrics were published.</small>
                                </div>
                              )}
                            </td>
                          </tr>
                        );
                      })}
                      </tbody>
                    </table>
                  </div>
                </details>
              </article>
            </section>
          );
        })}

        <details class="method-card">
          <summary class="method-summary">
            <div>
              <strong>Methodology</strong>
              <small>{target.methodology.runner} · {target.methodology.benchmark_style}</small>
