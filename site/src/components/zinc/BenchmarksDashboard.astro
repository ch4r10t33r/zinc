  <script is:inline>
    function initBenchmarksDashboard() {
      const targetTabs = Array.from(document.querySelectorAll('[data-bench-target-tab]'));
      const targetPanels = Array.from(document.querySelectorAll('[data-bench-target-panel]'));
      const scenarioTabs = Array.from(document.querySelectorAll('[data-bench-scenario-target]'));
      const scenarioPanels = Array.from(document.querySelectorAll('[data-bench-scenario-panel]'));

      function setActiveScenario(targetId, scenarioId) {
        for (const tab of scenarioTabs) {
          const active = tab.dataset.benchScenarioTarget === targetId && tab.dataset.benchScenario === scenarioId;
          tab.classList.toggle('active', active);
          tab.setAttribute('aria-pressed', active ? 'true' : 'false');
        }
        for (const panel of scenarioPanels) {
          const active = panel.dataset.benchScenarioPanel === targetId && panel.dataset.benchScenarioId === scenarioId;
          panel.hidden = !active;
          panel.classList.toggle('active', active);
        }
      }

      function setActiveTarget(targetId) {
        for (const tab of targetTabs) {
          const active = tab.dataset.benchTargetTab === targetId;
          tab.classList.toggle('active', active);
          tab.setAttribute('aria-selected', active ? 'true' : 'false');
        }
        for (const panel of targetPanels) {
          const active = panel.dataset.benchTargetPanel === targetId;
          panel.hidden = !active;
          panel.classList.toggle('active', active);
        }

        const panel = targetPanels.find((candidate) => candidate.dataset.benchTargetPanel === targetId);
        const activeScenarioTab = scenarioTabs.find((tab) => tab.dataset.benchScenarioTarget === targetId && tab.classList.contains('active'));
        const fallbackScenario = activeScenarioTab?.dataset.benchScenario || panel?.dataset.defaultScenario || 'core';
        setActiveScenario(targetId, fallbackScenario);
      }

      for (const tab of targetTabs) {
        tab.addEventListener('click', () => {
          const targetId = tab.dataset.benchTargetTab || targetTabs[0]?.dataset.benchTargetTab || 'rdna';
          setActiveTarget(targetId);
          history.replaceState(null, '', `#${targetId}`);
        });
      }

      for (const tab of scenarioTabs) {
        tab.addEventListener('click', () => {
          const targetId = tab.dataset.benchScenarioTarget || targetTabs[0]?.dataset.benchTargetTab || 'rdna';
          const scenarioId = tab.dataset.benchScenario || 'core';
          setActiveScenario(targetId, scenarioId);
        });
      }

      const knownTargets = new Set(targetTabs.map((tab) => tab.dataset.benchTargetTab).filter(Boolean));
      const hashedTarget = location.hash ? location.hash.slice(1) : null;
      const initialTarget = hashedTarget && knownTargets.has(hashedTarget)
        ? hashedTarget
        : (targetTabs[0]?.dataset.benchTargetTab || 'rdna');
      setActiveTarget(initialTarget);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initBenchmarksDashboard, { once: true });
    } else {
      initBenchmarksDashboard();
    }
  </script>
