    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .machine-card dt,
  .machine-card dd {
    margin: 0;
  }

  .machine-card dt {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .machine-card dd {
    font-weight: 700;
    margin-top: 0.12rem;
    font-size: 0.92rem;
    line-height: 1.35;
    overflow-wrap: anywhere;
  }

  .scenario-banner {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 1fr);
    gap: 0.8rem;
    align-items: start;
  }

  .scenario-banner h3 {
    margin-bottom: 0.25rem;
    font-size: 1.35rem;
  }

  .scenario-readout {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.65rem;
  }

  .readout-card {
    min-width: 0;
  }

  .readout-card span,
  .readout-card small {
    color: var(--color-text-muted);
  }

  .readout-card span {
    display: block;
    margin-bottom: 0.18rem;
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .readout-card strong {
    display: block;
    overflow-wrap: anywhere;
    line-height: 1.2;
  }

  .readout-card small {
    display: block;
    margin-top: 0.22rem;
    line-height: 1.35;
  }

  .scenario-highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-content: start;
  }

  .info-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.38rem 0.55rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--color-border) 78%, #d97706 22%);
    background: color-mix(in srgb, var(--bench-surface-soft) 86%, var(--color-bg) 14%);
    color: var(--color-text-muted);
    font-size: 0.78rem;
    line-height: 1.25;
  }

  .info-chip strong {
    color: var(--color-text);
    font-weight: 700;
  }

  .info-chip.positive {
    background: color-mix(in srgb, #16a34a 14%, var(--bench-surface-soft) 86%);
  }

  .info-chip.caution {
    background: color-mix(in srgb, #d97706 14%, var(--bench-surface-soft) 86%);
  }

  .info-chip.negative {
    background: color-mix(in srgb, #dc2626 14%, var(--bench-surface-soft) 86%);
  }

  .board-head {
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    align-items: start;
    margin-bottom: 0.75rem;
  }

  .board-head h3 {
    font-size: 1.05rem;
  }

  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem 0.85rem;
    align-items: center;
    color: var(--color-text-muted);
    font-size: 0.76rem;
  }

  .legend span {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .legend-swatch {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    display: inline-block;
  }

  .legend-swatch.zinc {
    background: #d97706;
  }

  .legend-swatch.baseline {
    background: #2563eb;
  }

  .legend-swatch.neutral {
    background: #64748b;
  }

  .decode-rank {
    display: grid;
    margin-bottom: 0.85rem;
    border: 1px solid color-mix(in srgb, var(--color-border) 78%, transparent);
    border-radius: 8px;
    overflow: hidden;
    background: var(--bench-surface-plain);
  }

  .rank-row {
    display: grid;
    grid-template-columns: minmax(240px, 0.8fr) minmax(420px, 1.55fr) minmax(112px, auto);
    gap: 0.9rem;
    align-items: center;
    padding: 0.72rem 0.78rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-border) 74%, transparent);
  }

  .rank-row:last-child {
    border-bottom: 0;
  }

  .rank-model {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    align-items: start;
    min-width: 0;
  }

  .rank-model strong {
    display: block;
    line-height: 1.25;
  }

  .rank-model small,
  .rank-ratio small,
  .latency-note {
    display: block;
    color: var(--color-text-muted);
    line-height: 1.35;
  }

  .rank-status {
    display: none;
  }

  .rank-bars {
    display: grid;
    gap: 0.58rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    min-width: 0;
  }

  .rank-metric-group {
    display: grid;
    gap: 0.28rem;
    min-width: 0;
  }

  .rank-metric-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.45rem;
    min-width: 0;
  }

  .rank-metric-title span {
    color: var(--color-text-muted);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .rank-metric-title .ratio-pill {
    padding: 0.16rem 0.38rem;
    font-size: 0.68rem;
  }

  .bar-line {
    display: grid;
    grid-template-columns: 3.6rem minmax(64px, 1fr) 6.2rem;
    gap: 0.55rem;
    align-items: center;
    font-variant-numeric: tabular-nums;
  }

  .bar-line span {
    color: var(--color-text-muted);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .bar-line strong {
    justify-self: end;
    font-size: 0.84rem;
    white-space: nowrap;
  }

  .bar-track {
    height: 0.48rem;
    border-radius: 999px;
    background: var(--bench-meter-track);
    overflow: hidden;
  }

  .bar-fill {
    display: block;
    height: 100%;
    border-radius: inherit;
  }

  .bar-fill.zinc {
    background: linear-gradient(90deg, #b45309, #f59e0b);
  }

  .bar-fill.baseline {
    background: linear-gradient(90deg, #1d4ed8, #60a5fa);
  }

  .rank-ratio {
    display: grid;
    justify-items: end;
    gap: 0.18rem;
    text-align: right;
  }

  .mobile-bench-list {
    display: none;
  }

  .mobile-model {
    display: grid;
    gap: 0.75rem;
    padding: 0.78rem 0;
    border-top: 1px solid color-mix(in srgb, var(--color-border) 78%, transparent);
  }

  .mobile-model:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .mobile-model:last-child {
    padding-bottom: 0;
  }

  .mobile-model-head,
  .mobile-metric-head {
    display: flex;
    justify-content: space-between;
    gap: 0.65rem;
    align-items: start;
  }

  .mobile-model-head strong {
    display: block;
    line-height: 1.25;
  }

  .mobile-model-head small {
    display: block;
    margin-top: 0.18rem;
    color: var(--color-text-muted);
  }

  .mobile-metric {
    display: grid;
    gap: 0.38rem;
  }

  .mobile-metric-head span {
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .table-wrap {
    overflow-x: auto;
    border-radius: 8px;
    border: 1px solid color-mix(in srgb, var(--color-border) 82%, transparent);
    background: var(--bench-surface-plain);
  }

  .raw-table-details {
    margin-top: 0.85rem;
    border-top: 1px solid color-mix(in srgb, var(--color-border) 78%, transparent);
    padding-top: 0.65rem;
  }

  .raw-table-details summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    align-items: center;
    color: var(--color-text);
  }

  .raw-table-details summary::-webkit-details-marker {
    display: none;
  }

  .raw-table-details summary::after {
    content: '+';
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.45rem;
    height: 1.45rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--color-border) 84%, transparent);
    color: var(--color-text-muted);
    font-weight: 800;
  }

  .raw-table-details[open] summary::after {
    content: '-';
  }

  .raw-table-details summary strong,
  .raw-table-details summary small {
    display: block;
  }

  .raw-table-details summary small {
    color: var(--color-text-muted);
    margin-top: 0.08rem;
  }

  .raw-table-details .table-wrap {
    margin-top: 0.7rem;
  }

  .bench-table {
    width: 100%;
    min-width: 1080px;
    border-collapse: collapse;
    font-variant-numeric: tabular-nums;
  }

  .bench-table thead th {
    position: sticky;
    top: 0;
    z-index: 2;
    background: var(--bench-table-head-bg);
    color: var(--bench-table-head-text);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.72rem 0.7rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-border) 84%, transparent);
    text-align: left;
  }

  .bench-table thead th:first-child {
    z-index: 3;
    left: 0;
  }

  .bench-table tbody tr:nth-child(odd) {
    background: var(--bench-row-odd);
  }

  .bench-table tbody tr:nth-child(even) {
    background: var(--bench-row-even);
  }

  .bench-table td,
  .bench-table th[scope='row'] {
    padding: 0.72rem 0.7rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-border) 74%, transparent);
    vertical-align: top;
  }

  .bench-table tbody tr:last-child td,
  .bench-table tbody tr:last-child th[scope='row'] {
    border-bottom: 0;
  }

  .bench-table th:first-child,
  .bench-table td:first-child {
    position: sticky;
    left: 0;
    z-index: 1;
    background: inherit;
  }

  .model-cell {
    min-width: 260px;
  }

  .model-row {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.55rem;
    align-items: start;
  }

  .model-cell strong {
    display: block;
    margin-bottom: 0.08rem;
    font-size: 0.94rem;
    line-height: 1.3;
  }

  .model-cell small {
    display: block;
    margin-top: 0.16rem;
    line-height: 1.35;
  }

  .rank-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.6rem;
    height: 1.6rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: #c45c13;
    font-size: 0.72rem;
    font-weight: 800;
  }

  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.42rem;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    padding: 0.15rem 0.46rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-accent) 10%, var(--bench-surface-soft) 90%);
    border: 1px solid color-mix(in srgb, var(--color-accent) 22%, var(--color-border) 78%);
    color: var(--color-text-muted);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .metric-stack,
  .status-cell {
    display: grid;
    gap: 0.38rem;
    min-width: 180px;
  }

  .backend-line {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.52rem;
    align-items: start;
  }

  .backend-line strong {
    display: block;
    margin: 0;
    font-size: 0.9rem;
  }

  .backend-line small {
    display: block;
    margin-top: 0.08rem;
    color: var(--color-text-muted);
    line-height: 1.25;
  }

  .backend-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 999px;
    font-size: 0.66rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .backend-pill.zinc {
    background: color-mix(in srgb, #d97706 18%, transparent);
    color: #d97706;
  }

  .backend-pill.baseline {
    background: color-mix(in srgb, #2563eb 16%, transparent);
    color: #2563eb;
  }

  .metric-footer {
    display: grid;
    gap: 0.22rem;
  }

  .metric-footer small {
    color: var(--color-text-muted);
    line-height: 1.25;
  }

  .metric-footer.compact {
    gap: 0.14rem;
  }

  .ratio-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    padding: 0.15rem 0.48rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 800;
    white-space: nowrap;
  }

  .ratio-pill.positive {
    background: color-mix(in srgb, #16a34a 18%, transparent);
    color: #15803d;
  }

  .ratio-pill.caution {
    background: color-mix(in srgb, #d97706 18%, transparent);
    color: #b45309;
  }

  .ratio-pill.negative {
    background: color-mix(in srgb, #dc2626 18%, transparent);
    color: #b91c1c;
  }

  .ratio-pill.neutral {
    background: color-mix(in srgb, #64748b 18%, transparent);
    color: #64748b;
  }

  .metric-missing {
    display: grid;
    gap: 0.14rem;
    min-width: 170px;
    padding: 0.55rem 0.65rem;
    border-radius: 8px;
    border: 1px dashed color-mix(in srgb, var(--color-border) 82%, #d97706 18%);
    background: color-mix(in srgb, var(--bench-surface-soft) 86%, var(--color-bg) 14%);
  }

  .metric-missing strong {
    display: block;
    margin: 0;
    font-size: 0.78rem;
  }

  .metric-missing small {
    color: var(--color-text-muted);
    line-height: 1.35;
    font-size: 0.76rem;
  }

  .meter-track {
    height: 6px;
    border-radius: 999px;
    background: var(--bench-meter-track);
    overflow: hidden;
  }

  .meter-fill {
    height: 100%;
    border-radius: 999px;
  }

  .meter-fill.positive {
    background: linear-gradient(90deg, #16803c, #4ade80);
  }

  .meter-fill.caution {
    background: linear-gradient(90deg, #b45309, #f59e0b);
  }

  .meter-fill.negative {
    background: linear-gradient(90deg, #c2410c, #fb923c);
  }

  .meter-fill.neutral {
    background: linear-gradient(90deg, #64748b, #94a3b8);
  }

  .status-cell {
    min-width: 190px;
  }

  .status-cell small {
    color: var(--color-text-muted);
    line-height: 1.35;
  }

  .status-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    padding: 0.18rem 0.52rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .status-pill.positive {
    background: color-mix(in srgb, #16a34a 18%, transparent);
    color: #15803d;
  }

  .status-pill.caution {
    background: color-mix(in srgb, #d97706 18%, transparent);
    color: #b45309;
  }

  .status-pill.negative {
    background: color-mix(in srgb, #dc2626 18%, transparent);
    color: #b91c1c;
  }

  .method-card {
    padding: 0;
    overflow: hidden;
  }

  .method-summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    align-items: start;
    padding: 0.85rem 0.95rem;
  }

  .method-summary::-webkit-details-marker {
    display: none;
  }

  .method-summary strong {
    display: block;
    font-size: 0.92rem;
    margin-bottom: 0.08rem;
  }

  .method-summary small,
  .method-summary span {
    color: var(--color-text-muted);
    line-height: 1.35;
  }

  .method-card[open] .method-summary {
    border-bottom: 1px solid color-mix(in srgb, var(--color-border) 82%, transparent);
  }

  .method-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    padding: 0.75rem 0.95rem 0;
  }

  .method-links a {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.28rem 0.55rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--color-border) 80%, #d97706 20%);
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 700;
    background: color-mix(in srgb, var(--bench-surface-soft) 88%, var(--color-bg) 12%);
  }

  .method-links a:hover {
    border-color: color-mix(in srgb, #d97706 68%, var(--color-border) 32%);
    color: #b45309;
  }

  .method-list {
    margin: 0;
    padding: 0.85rem 0.95rem 0.95rem 2rem;
    display: grid;
    gap: 0.45rem;
  }

  @media (max-width: 1100px) {
    .hero,
    .coverage-panel,
    .panel-header,
    .scenario-banner {
      grid-template-columns: 1fr;
    }

    .coverage-grid {
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    }

    .scenario-readout {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .rank-row {
      grid-template-columns: minmax(210px, 0.85fr) minmax(320px, 1.25fr) minmax(98px, auto);
    }

    .rank-bars {
      grid-template-columns: 1fr;
    }

    .hero-stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    :global(main.container) {
      max-width: 100%;
    }

    .hero-stats,
    .summary-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .summary-card:last-child {
      grid-column: 1 / -1;
    }

    .machine-card {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .machine-card div:nth-child(n + 5) {
      display: none;
    }

    .target-tab-stats,
    .scenario-tab-stats {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .board-head {
      flex-direction: column;
    }

    .target-tabs,
    .scenario-tabs {
      grid-template-columns: 1fr;
    }

    .scenario-readout {
      grid-template-columns: 1fr;
    }

    .decode-rank {
      margin-bottom: 0.9rem;
    }

    .rank-row {
      grid-template-columns: 1fr;
      gap: 0.58rem;
      padding: 0.78rem 0.72rem;
    }

    .rank-ratio {
      justify-items: start;
      text-align: left;
    }

    .rank-bars {
      grid-template-columns: 1fr;
    }

    .bar-line {
      grid-template-columns: 3.1rem minmax(56px, 1fr) 5.55rem;
      gap: 0.45rem;
    }

    .bar-line strong {
      font-size: 0.78rem;
    }

    .table-wrap {
      display: none;
    }

    .raw-table-details {
      display: none;
    }

    .mobile-bench-list {
      display: grid;
      gap: 0;
    }

    .method-summary {
      flex-direction: column;
    }
  }

  /* Visual reset: make the benchmark page read like a dense performance tool. */
  :global(main.container) {
    --bench-accent: #c45c13;
    --bench-control: #334155;
    --bench-control-soft: color-mix(in srgb, #334155 7%, var(--color-bg) 93%);
    --bench-surface: var(--color-bg);
    --bench-surface-plain: color-mix(in srgb, var(--color-bg) 97%, var(--color-bg-alt) 3%);
    --bench-surface-soft: color-mix(in srgb, var(--color-bg-alt) 62%, var(--color-bg) 38%);
    --bench-tab-active: color-mix(in srgb, var(--bench-control) 10%, var(--color-bg) 90%);
    --bench-table-head-bg: color-mix(in srgb, var(--color-bg-alt) 88%, var(--color-bg) 12%);
    --bench-table-head-text: color-mix(in srgb, var(--color-text) 86%, var(--bench-control) 14%);
    --bench-row-odd: var(--color-bg);
    --bench-row-even: color-mix(in srgb, var(--color-bg-alt) 48%, var(--color-bg) 52%);
    --bench-meter-track: color-mix(in srgb, var(--color-border) 54%, var(--color-bg-alt) 46%);
    --bench-shadow: none;
  }

  .hero {
    align-items: start;
    padding-bottom: 1.15rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-border) 82%, transparent);
  }

  .eyebrow {
    color: var(--bench-accent);
  }

  .hero h1 {
    max-width: 12ch;
  }

  .hero-stats {
    align-self: stretch;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0;
    border: 1px solid color-mix(in srgb, var(--color-border) 86%, transparent);
    border-radius: 8px;
    overflow: hidden;
    background: var(--bench-surface-plain);
  }

  .stat-card,
  .summary-card,
  .scenario-banner,
  .machine-card,
  .readout-card {
    border: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }

  .stat-card {
    min-height: 5.1rem;
    border-right: 1px solid color-mix(in srgb, var(--color-border) 76%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--color-border) 76%, transparent);
  }

  .stat-card:nth-child(2n) {
    border-right: 0;
  }

  .stat-card:nth-last-child(-n + 2) {
    border-bottom: 0;
  }

