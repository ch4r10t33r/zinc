#version 460
// ZINC - Q4_K MoE fused gate+up+SwiGLU DMMV (K-parallel wave64).
//
// Same routing and dequantization shape as dmmv_q4k_fused_gate_up_moe, but
// writes silu(W_gate[expert] * x) * (W_up[expert] * x) directly to the
// per-expert activation buffer. This removes the standalone MoE SwiGLU
// dispatch and its gate/up intermediate reads. The shader intentionally uses
// one row per workgroup; the dual-output Q4_K path is register-pressure bound
// enough on RDNA4 that this beats the two-row variant.

#extension GL_EXT_shader_explicit_arithmetic_types : require
#extension GL_EXT_shader_16bit_storage : require
#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require
#extension GL_EXT_control_flow_attributes : enable

layout(local_size_x = 64) in;

layout(constant_id = 0) const uint SPEC_BLOCKS_PER_ROW = 0u;

layout(push_constant) uniform PushConstants {
    uint M;
    uint K;
    uint expert_stride;
    uint x_expert_stride;
    uint x_offset;
    uint y_offset;
};

layout(set = 0, binding = 0) readonly buffer MatrixAGate { uint a_gate_u32[]; };
layout(set = 0, binding = 1) readonly buffer MatrixAUp   { uint a_up_u32[];   };
layout(set = 0, binding = 2) readonly buffer VectorX     { vec4 x_v4[];       };
layout(set = 0, binding = 3) writeonly buffer VectorY    { float y_act[];     };
layout(set = 0, binding = 4) readonly buffer MoeRouting  { uint routing_data[]; };

const uint Q4K_BLOCK_U32 = 36u;

shared float s_sg_gate[8];
shared float s_sg_up[8];

vec4 unpack_nibbles_lo(uint v) {
    return vec4(
        float(v & 0xFu),
        float((v >> 8) & 0xFu),
        float((v >> 16) & 0xFu),
        float((v >> 24) & 0xFu)
    );
}

vec4 unpack_nibbles_hi(uint v) {
    return vec4(
        float((v >> 4) & 0xFu),
        float((v >> 12) & 0xFu),
        float((v >> 20) & 0xFu),
        float((v >> 28) & 0xFu)
    );
}

void main() {
    uint tid = gl_LocalInvocationID.x;
    uint wg_id_x = gl_WorkGroupID.x;
    uint expert_slot = gl_WorkGroupID.y;

    uint expert_id = routing_data[expert_slot];
    uint a_offset_bytes = expert_id * expert_stride;

    const uint THREADS_PER_BLOCK = 16u;
    const uint it_size = 64u / THREADS_PER_BLOCK;
    uint itid = tid % THREADS_PER_BLOCK;
    uint ix = tid / THREADS_PER_BLOCK;

    uint il = itid / 4u;
    uint ir = itid % 4u;
    uint v_im = il / 2u;
    uint v_in = il % 2u;
    uint l0 = 4u * (2u * ir + v_in);
    uint q_offset_in_half = 32u * v_im + l0;
    uint y_offset_local = 64u * v_im + l0;
    uint shift = v_im * 16u;

    uint x_global_base_v4 = (x_offset / 16u) + (expert_slot * x_expert_stride) / 4u;
    uint a_base_u32 = a_offset_bytes / 4u;
    uint blocks_per_row = (SPEC_BLOCKS_PER_ROW != 0u) ? SPEC_BLOCKS_PER_ROW : (K / 256u);
    uint y_base = y_offset / 4u + expert_slot * M;

    uint row = wg_id_x;
    if (row >= M) return;

    uint row_u32 = a_base_u32 + row * blocks_per_row * Q4K_BLOCK_U32;
    float sum_gate = 0.0;
    float sum_up = 0.0;

    [[unroll]] for (uint i = ix; i < blocks_per_row; i += it_size) {
        uint blk_u32 = row_u32 + i * Q4K_BLOCK_U32;

            uint b_idx = (i * 256u + y_offset_local) / 4u;
            vec4 by0 = x_v4[x_global_base_v4 + b_idx];
            vec4 by1 = x_v4[x_global_base_v4 + b_idx + 8u];
            uint b_idx2 = (i * 256u + y_offset_local + 128u) / 4u;
            vec4 by2 = x_v4[x_global_base_v4 + b_idx2];
            vec4 by3 = x_v4[x_global_base_v4 + b_idx2 + 8u];

            {
                uint d_dmin = a_gate_u32[blk_u32];
                float d_val = unpackHalf2x16(d_dmin & 0xFFFFu).x;
                float dmin_val = unpackHalf2x16(d_dmin >> 16).x;

                uint sc0 = a_gate_u32[blk_u32 + 1u];
                uint sc1 = a_gate_u32[blk_u32 + 2u];
                uint sc2 = a_gate_u32[blk_u32 + 3u];

                uint qs_u32_0 = a_gate_u32[blk_u32 + 4u + q_offset_in_half / 4u];
                uint qs_u32_1 = a_gate_u32[blk_u32 + 4u + q_offset_in_half / 4u + 16u];

                vec4 q0_lo = unpack_nibbles_lo(qs_u32_0);
                vec4 q0_hi = unpack_nibbles_hi(qs_u32_0);
                vec4 q1_lo = unpack_nibbles_lo(qs_u32_1);
                vec4 q1_hi = unpack_nibbles_hi(qs_u32_1);

                uint sc0_v = sc0 >> shift;
                uint sc1_v = sc1 >> shift;
                uint sc2_v = sc2 >> shift;

                float sc_a = float(sc0_v & 0x3Fu);
                float mn_a = float(sc1_v & 0x3Fu);
                float sc_b = float((sc0_v >> 8u) & 0x3Fu);
                float mn_b = float((sc1_v >> 8u) & 0x3Fu);
                float sc_c = float((sc2_v & 0xFu) | ((sc0_v & 0xC0u) >> 2u));
                float mn_c = float(((sc2_v & 0xF0u) >> 4u) | ((sc1_v & 0xC0u) >> 2u));
                float sc_d = float(((sc2_v >> 8u) & 0xFu) | (((sc0_v >> 8u) & 0xC0u) >> 2u));
                float mn_d = float((((sc2_v >> 8u) & 0xF0u) >> 4u) | (((sc1_v >> 8u) & 0xC0u) >> 2u));

                float f0 = d_val * sc_a, b0 = dmin_val * mn_a;
                float f1 = d_val * sc_b, b1 = dmin_val * mn_b;
                float f2 = d_val * sc_c, b2 = dmin_val * mn_c;
                float f3 = d_val * sc_d, b3 = dmin_val * mn_d;

                sum_gate += dot(vec4(f0) * q0_lo - vec4(b0), by0);
                sum_gate += dot(vec4(f1) * q0_hi - vec4(b1), by1);
                sum_gate += dot(vec4(f2) * q1_lo - vec4(b2), by2);
                sum_gate += dot(vec4(f3) * q1_hi - vec4(b3), by3);
            }

            {
                uint d_dmin = a_up_u32[blk_u32];
                float d_val = unpackHalf2x16(d_dmin & 0xFFFFu).x;
                float dmin_val = unpackHalf2x16(d_dmin >> 16).x;

                uint sc0 = a_up_u32[blk_u32 + 1u];
                uint sc1 = a_up_u32[blk_u32 + 2u];
                uint sc2 = a_up_u32[blk_u32 + 3u];

                uint qs_u32_0 = a_up_u32[blk_u32 + 4u + q_offset_in_half / 4u];
                uint qs_u32_1 = a_up_u32[blk_u32 + 4u + q_offset_in_half / 4u + 16u];

                vec4 q0_lo = unpack_nibbles_lo(qs_u32_0);
                vec4 q0_hi = unpack_nibbles_hi(qs_u32_0);
                vec4 q1_lo = unpack_nibbles_lo(qs_u32_1);
                vec4 q1_hi = unpack_nibbles_hi(qs_u32_1);

                uint sc0_v = sc0 >> shift;
                uint sc1_v = sc1 >> shift;
                uint sc2_v = sc2 >> shift;

                float sc_a = float(sc0_v & 0x3Fu);
                float mn_a = float(sc1_v & 0x3Fu);
                float sc_b = float((sc0_v >> 8u) & 0x3Fu);
                float mn_b = float((sc1_v >> 8u) & 0x3Fu);
                float sc_c = float((sc2_v & 0xFu) | ((sc0_v & 0xC0u) >> 2u));
                float mn_c = float(((sc2_v & 0xF0u) >> 4u) | ((sc1_v & 0xC0u) >> 2u));
                float sc_d = float(((sc2_v >> 8u) & 0xFu) | (((sc0_v >> 8u) & 0xC0u) >> 2u));
                float mn_d = float((((sc2_v >> 8u) & 0xF0u) >> 4u) | (((sc1_v >> 8u) & 0xC0u) >> 2u));

                float f0 = d_val * sc_a, b0 = dmin_val * mn_a;
                float f1 = d_val * sc_b, b1 = dmin_val * mn_b;
                float f2 = d_val * sc_c, b2 = dmin_val * mn_c;
                float f3 = d_val * sc_d, b3 = dmin_val * mn_d;

                sum_up += dot(vec4(f0) * q0_lo - vec4(b0), by0);
                sum_up += dot(vec4(f1) * q0_hi - vec4(b1), by1);
                sum_up += dot(vec4(f2) * q1_lo - vec4(b2), by2);
                sum_up += dot(vec4(f3) * q1_hi - vec4(b3), by3);
            }
    }

    sum_gate = subgroupAdd(sum_gate);
    sum_up = subgroupAdd(sum_up);
    if (gl_NumSubgroups > 1u) {
        if (subgroupElect()) {
            s_sg_gate[gl_SubgroupID] = sum_gate;
            s_sg_up[gl_SubgroupID] = sum_up;
        }
        barrier();
        if (tid == 0u) {
            for (uint sg = 1u; sg < gl_NumSubgroups; sg++) {
                sum_gate += s_sg_gate[sg];
                sum_up += s_sg_up[sg];
            }
        }
        barrier();
    }
    if (tid == 0u) {
        float sig = 1.0 / (1.0 + exp(-sum_gate));
        y_act[y_base + row] = (sum_gate * sig) * sum_up;
    }
}
