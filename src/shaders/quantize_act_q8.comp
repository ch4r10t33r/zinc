#version 460
// ZINC — one-shot per-token activation quantizer for the int8 DP4a dense-down
// prefill GEMM (Qwen3.6-27B). The Q6_K dense-down GEMM is an f32-FMA local
// optimum (cycle 19 occupancy-lift and cycle 22 wide-tile both regressed), so
// the only remaining throughput lever is to drop the inner product to hardware
// int8 dot4 (v_dot4_i32_i8). Cycle 9's DP4a attempt died because it re-quantized
// the activation once per row-tile (~160x redundant); this kernel quantizes the
// f32 SwiGLU activation exactly once into packed int8 + per-32-block scales.
//
// Block granularity is 32 elements (matching the GEMM's BK tile and llama.cpp's
// Q8_0 block size), so activation outliers are scaled locally — far more robust
// than a single per-token scale for the unnormalized SwiGLU output.
//
// Layout: src is token-major [token][K] f32 (the dense-FFN scratch_swiglu).
//   dst_packed: token-major [token][K/4] uint, 4 int8 lanes per uint (lane i = k+i)
//   dst_scale:  token-major [token][K/32] f32, scale = absmax/127 per 32-block

#extension GL_EXT_control_flow_attributes : require

layout(local_size_x = 256) in;

layout(push_constant) uniform PushConstants {
    uint n_tokens;
    uint K;            // inter_dim, multiple of 32
    uint blocks_per_token; // K / 32
    uint total_blocks; // n_tokens * blocks_per_token
};

layout(set = 0, binding = 0) readonly buffer Src   { float src[]; };
layout(set = 0, binding = 1) writeonly buffer Dst  { uint dst_packed[]; };
layout(set = 0, binding = 2) writeonly buffer Scl  { float dst_scale[]; };

void main() {
    const uint block = gl_GlobalInvocationID.x;
    if (block >= total_blocks) return;

    const uint token = block / blocks_per_token;
    const uint blk_in_tok = block - token * blocks_per_token;
    const uint base = token * K + blk_in_tok * 32u;

    float vals[32];
    float amax = 0.0;
    [[unroll]] for (uint i = 0u; i < 32u; i++) {
        float v = src[base + i];
        vals[i] = v;
        amax = max(amax, abs(v));
    }

    const float scale = amax / 127.0;
    const float inv = (amax > 0.0) ? (127.0 / amax) : 0.0;
    dst_scale[block] = scale;

    // Pack 4 signed int8 lanes per uint, lane i (low byte first) = element 4*p+i.
    const uint out_base = base >> 2; // (token*K + blk*32) / 4
    [[unroll]] for (uint p = 0u; p < 8u; p++) {
        uint packed = 0u;
        [[unroll]] for (uint b = 0u; b < 4u; b++) {
            int q = int(round(vals[p * 4u + b] * inv));
            q = clamp(q, -127, 127);
            packed |= (uint(q) & 0xFFu) << (b * 8u);
        }
        dst_packed[out_base + p] = packed;
    }
}
