---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import TerminalWindow from '../../components/TerminalWindow.astro';
import { buildBreadcrumbList } from '../../lib/structured-data';
import benchmarkData from '../../data/zinc-performance.json';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://zolotukhin.ai';
const breadcrumbItems = [
  { name: 'Home', href: '/' },
  { name: 'ZINC' },
];
const discordUrl = 'https://discord.gg/QRUgWH2aGV';

function metricMedian(summary: any) {
  return summary?.median ?? summary?.avg ?? null;
}

function formatTokNumber(value: number | null | undefined, digits = 2) {
  if (value == null || Number.isNaN(value)) return 'n/a';
  return value.toFixed(digits);
}

function formatTok(value: number | null | undefined, digits = 2) {
  const formatted = formatTokNumber(value, digits);
  return formatted === 'n/a' ? formatted : `${formatted} tok/s`;
}

function formatMultiplier(zinc: number | null | undefined, baseline: number | null | undefined) {
  if (zinc == null || baseline == null || Number.isNaN(zinc) || Number.isNaN(baseline) || baseline <= 0) return 'n/a';
  return `${(zinc / baseline).toFixed(2)}x`;
}

function formatPercent(value: number | null | undefined) {
  if (value == null || Number.isNaN(value)) return 'n/a';
  return `${Math.round(value)}%`;
}

function formatRefreshDate(iso: string | null | undefined) {
  return iso?.slice(0, 10) ?? 'latest';
}

function targetById(id: string) {
  return benchmarkData.targets.find((target: any) => target.id === id) ?? null;
}

function modelById(target: any, id: string) {
  return target?.models?.find((model: any) => model.id === id) ?? null;
}

function displayModelLabel(label: string) {
  return label
    .replace(/\bQ4_K_XL\b/g, 'Q4K XL')
    .replace(/\bQ4_K_M\b/g, 'Q4K M');
}

const rdnaTarget = targetById('rdna');
const metalTarget = targetById('metal');
const rdna35 = modelById(rdnaTarget, 'qwen36-35b-a3b-q4k-xl');
const metal35 = modelById(metalTarget, 'qwen36-35b-a3b-q4k-xl');

const rdna35Decode = metricMedian(rdna35?.zinc?.decode_tps);
const rdna35BaselineDecode = metricMedian(rdna35?.baseline?.decode_tps);
const metal35Decode = metricMedian(metal35?.zinc?.decode_tps);

const homeDescription = `Fastest measured local LLM inference for AMD Radeon GPUs. ZINC beats llama.cpp across the current five-model RDNA4 suite, led by ${formatTokNumber(rdna35Decode)} tok/s on Qwen3.6-35B-A3B — ${formatMultiplier(rdna35Decode, rdna35BaselineDecode)} llama.cpp, no ROCm.`;
const appDescription = `LLM inference engine for AMD Radeon GPUs (RDNA4/RDNA3) and Apple Silicon, built with Zig, Vulkan compute shaders, and Metal. The current RDNA4 sweep beats llama.cpp on all five published models.`;
const performanceAnswer = `On the Radeon AI PRO R9700 (32GB, 576 GB/s), the current validated ZINC plain-decode number is ${formatTokNumber(rdna35Decode)} tok/s on Qwen3.6-35B-A3B-UD-Q4_K_XL - ${formatMultiplier(rdna35Decode, rdna35BaselineDecode)} llama.cpp on the same machine. The current RDNA4 suite is ahead of llama.cpp on decode, prefill, and model-level overall across all five published models. On the current Apple Silicon validation box, a Mac Studio (Mac16,9) with Apple M4 Max, 40-core GPU, and 64 GB unified memory, Qwen3.6-35B-A3B-UD-Q4_K_XL measures ${formatTokNumber(metal35Decode)} tok/s decode in the Metal benchmark.`;

function ratioX(zinc: number | null | undefined, baseline: number | null | undefined) {
  if (zinc == null || baseline == null || Number.isNaN(zinc) || Number.isNaN(baseline) || baseline <= 0) return null;
  return zinc / baseline;
}

function formatRatioX(zinc: number | null | undefined, baseline: number | null | undefined) {
  const r = ratioX(zinc, baseline);
  return r == null ? 'n/a' : `${r.toFixed(2)}x`;
}

function ratioTone(zinc: number | null | undefined, baseline: number | null | undefined) {
  const r = ratioX(zinc, baseline);
  if (r == null) return 'neutral';
  if (r >= 1) return 'win';
  if (r >= 0.8) return 'close';
  return 'behind';
}

function barPct(value: number | null | undefined, max: number | null | undefined) {
  if (value == null || Number.isNaN(value) || max == null || max <= 0) return 0;
  return Math.max(3, Math.min(100, (value / max) * 100));
}

function buildBoard(target: any, ids: string[]) {
  const rows = ids
    .map((id) => modelById(target, id))
    .filter(Boolean)
    .map((model: any) => ({
      label: displayModelLabel(model.label ?? model.id),
      zincDecode: metricMedian(model.zinc?.decode_tps),
      baselineDecode: metricMedian(model.baseline?.decode_tps),
      zincPrefill: metricMedian(model.zinc?.prefill_tps),
      baselinePrefill: metricMedian(model.baseline?.prefill_tps),
      overallPct: model.comparison?.overall_pct_of_baseline ?? null,
      endToEndPct: model.comparison?.end_to_end_pct_of_baseline ?? null,
    }));
  const decodeMax = Math.max(0, ...rows.flatMap((r) => [r.zincDecode, r.baselineDecode]).filter((v): v is number => v != null && !Number.isNaN(v)));
  const prefillMax = Math.max(0, ...rows.flatMap((r) => [r.zincPrefill, r.baselinePrefill]).filter((v): v is number => v != null && !Number.isNaN(v)));
  return { rows, decodeMax, prefillMax };
}

const rdnaBoard = buildBoard(rdnaTarget, [
  'qwen36-35b-a3b-q4k-xl',
  'qwen35-9b-q4k-m',
  'qwen36-27b-q4k-m',
  'gemma4-26b-a4b-q4k-m',
  'gemma4-31b-q4k-m',
]);

const metalBoard = buildBoard(metalTarget, [
  'qwen36-35b-a3b-q4k-xl',
  'qwen3-8b-q4k-m',
  'gemma4-26b-a4b-q4k-m',
  'gemma4-31b-q4k-m',
  'qwen36-27b-q4k-m',
]);

const rdnaModelCount = rdnaBoard.rows.length;
const rdnaDecodeWins = rdnaBoard.rows.filter((row) => (ratioX(row.zincDecode, row.baselineDecode) ?? 0) >= 1).length;
const rdnaPrefillWins = rdnaBoard.rows.filter((row) => (ratioX(row.zincPrefill, row.baselinePrefill) ?? 0) >= 1).length;
const rdnaOverallWins = rdnaBoard.rows.filter((row) => (row.overallPct ?? 0) >= 100).length;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      name: 'ZINC',
      description: appDescription,
      applicationCategory: 'DeveloperApplication',
      operatingSystem: 'Linux, macOS',
      url: `${siteUrl}/zinc`,
      codeRepository: 'https://github.com/zolotukhin/zinc',
      author: {
        '@type': 'Person',
        name: 'Stepan Zolotukhin',
        url: `${siteUrl}/about`,
      },
      keywords: 'AMD GPU LLM inference, AMD inference engine, Radeon LLM inference, RDNA4 inference, RDNA3 inference, RX 9070 XT, RX 7900 XTX, Radeon AI PRO R9700, run LLM on AMD GPU without ROCm, Vulkan compute, Zig, TurboQuant, KV cache compression, OpenAI API, local AI, vLLM alternative, llama.cpp alternative, ROCm alternative',
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'Does ZINC work on AMD consumer GPUs like the RX 9070 XT?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes. ZINC is built specifically for AMD RDNA3 and RDNA4 consumer GPUs including the RX 7900 XTX, RX 9070 XT, and Radeon AI PRO R9700. It uses Vulkan compute instead of ROCm, so it works on hardware that vLLM and most CUDA-based tools cannot use.',
          },
        },
        {
          '@type': 'Question',
          name: 'How do I run LLM inference on an AMD Radeon GPU without ROCm?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'ZINC runs LLM inference on AMD Radeon GPUs through Vulkan compute, so you do not need ROCm at all. Install a Vulkan 1.3 driver (RADV or AMDVLK), build ZINC with zig build -Doptimize=ReleaseFast, and point it at a GGUF model. This is the fastest path to local LLM inference on RDNA3 and RDNA4 cards such as the RX 7900 XTX, RX 9070 XT, and Radeon AI PRO R9700.',
          },
        },
        {
          '@type': 'Question',
          name: 'Which AMD GPUs are fastest for local LLM inference with ZINC?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: `The Radeon AI PRO R9700 (32 GB, 576 GB/s) is the primary RDNA4 tuning target and the fastest validated card: ${formatTokNumber(rdna35Decode)} tok/s decode on Qwen3.6-35B-A3B, ${formatMultiplier(rdna35Decode, rdna35BaselineDecode)} llama.cpp on the same machine. The RX 9070 and RX 9070 XT share the RDNA4 path, and RDNA3 cards (RX 7900 XTX, RX 7900 XT, RX 7800 XT, RX 7700 XT, RX 7600) are also supported.`,
          },
        },
        {
          '@type': 'Question',
          name: 'How does ZINC compare to llama.cpp and vLLM?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'vLLM requires ROCm which does not support RDNA3/RDNA4 consumer GPUs. llama.cpp supports Vulkan and Metal but treats consumer hardware as an afterthought. ZINC is built from scratch with hand-tuned Vulkan shaders for AMD and native Metal shaders for Apple Silicon, plus an OpenAI-compatible API and built-in chat UI.',
          },
        },
        {
          '@type': 'Question',
          name: 'What performance does ZINC achieve on RDNA4 and Apple Silicon?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: performanceAnswer,
          },
        },
        {
          '@type': 'Question',
          name: 'What is TurboQuant and how does it help?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'TurboQuant is ZINC\'s KV-compression direction and public implementation spec for 2-4 bit cache compression. It is part of the roadmap and not the reason for the current benchmark numbers on the public site.',
          },
        },
      ],
    },
    buildBreadcrumbList(siteUrl, breadcrumbItems),
  ],
};
---

<BaseLayout
  title="ZINC — Fastest Measured AMD LLM Inference Without ROCm"
  description={homeDescription}
  keywords="ZINC, AMD GPU LLM inference, AMD inference engine, Radeon LLM inference, RDNA4 inference, RDNA3 inference, run LLM on AMD GPU without ROCm, RX 9070 XT, RX 9070, RX 7900 XTX, RX 7900 XT, RX 7800 XT, RX 7700 XT, RX 7600, Radeon AI PRO R9700, Vulkan compute, Zig, TurboQuant, KV cache compression, vLLM alternative, llama.cpp alternative, ROCm alternative, OpenAI compatible API, local AI, Apple Silicon Metal inference, GGUF, Qwen, Gemma"
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} />
  <section class="hero">
    <img src="/zinc-logo.png" alt="ZINC inference engine logo — lightning bolt on circuit board" class="logo" width="120" height="120" />
    <p class="hero-eyebrow">AMD RDNA4 local LLM inference</p>
    <h1>Fastest measured local inference for AMD GPUs</h1>
    <p class="tagline">ZINC beats llama.cpp across the current five-model RDNA4 headline sweep: decode, prefill, end-to-end, and model-level overall. Hand-tuned Vulkan shaders, no ROCm.</p>
    <p class="hero-platforms"><strong>Runs on:</strong> Linux (AMD Radeon, Intel Arc Xe2 — experimental) and macOS (Apple Silicon M1–M5). <strong>Windows is not supported.</strong></p>
    <div class="hero-links">
      <a href="https://github.com/zolotukhin/zinc" class="hero-link">
        <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        View on GitHub
      </a>
      <a href="/zinc/benchmarks/" class="hero-link hero-link-benchmarks">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 19h16"/><path d="M7 16V9"/><path d="M12 16V5"/><path d="M17 16v-4"/></svg>
        Benchmarks
      </a>
      <a href={discordUrl} class="hero-link hero-link-discord">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M20.317 4.369A19.791 19.791 0 0015.558 3c-.206.375-.446.872-.61 1.264a18.27 18.27 0 00-5.896 0A12.64 12.64 0 008.44 3a19.736 19.736 0 00-4.76 1.369C.533 9.091-.32 13.699.099 18.243a19.9 19.9 0 005.993 3.03c.486-.665.918-1.368 1.288-2.109-.709-.268-1.388-.602-2.028-.99.17-.124.336-.252.496-.385 3.915 1.84 8.163 1.84 12.032 0 .162.133.328.261.496.385-.642.39-1.323.724-2.033.992.37.739.8 1.442 1.288 2.107a19.861 19.861 0 005.995-3.03c.492-5.265-.84-9.831-3.31-13.874zM8.02 15.331c-1.182 0-2.157-1.085-2.157-2.419 0-1.334.956-2.419 2.157-2.419 1.209 0 2.176 1.094 2.157 2.419 0 1.334-.956 2.419-2.157 2.419zm7.96 0c-1.182 0-2.157-1.085-2.157-2.419 0-1.334.956-2.419 2.157-2.419 1.209 0 2.176 1.094 2.157 2.419 0 1.334-.948 2.419-2.157 2.419z"/></svg>
        Join ZINC Discord
      </a>
    </div>
  </section>

  <section class="amd-sweep" aria-labelledby="amd-sweep-heading">
    <div class="sweep-header">
      <div>
        <p class="section-kicker">Current public sweep</p>
        <h2 id="amd-sweep-heading">AMD RDNA4 — Radeon AI PRO R9700</h2>
      </div>
      <span class="sweep-machine">32 GB VRAM · 576 GB/s · {formatRefreshDate(rdnaTarget?.generated_at)}</span>
    </div>

    <div class="perf-stats">
      <article class="perf-stat highlight">
        <strong>{rdnaDecodeWins}/{rdnaModelCount}</strong>
        <span>decode wins</span>
        <small>ZINC vs llama.cpp</small>
      </article>
      <article class="perf-stat">
        <strong>{rdnaPrefillWins}/{rdnaModelCount}</strong>
        <span>prefill wins</span>
        <small>same prompts, same weights</small>
      </article>
      <article class="perf-stat">
        <strong>{rdnaOverallWins}/{rdnaModelCount}</strong>
        <span>overall wins</span>
        <small>phase wall-time basis</small>
      </article>
      <article class="perf-stat">
        <strong>{formatTokNumber(rdna35Decode, 1)}</strong>
        <span>tok/s top decode</span>
        <small>Qwen3.6 35B A3B</small>
      </article>
    </div>

    <div class="perf-board rdna-showcase" role="img" aria-label="ZINC vs llama.cpp throughput on AMD RDNA4">
      <div class="perf-board-legend">
        <span><i class="perf-swatch zinc"></i>ZINC</span>
        <span><i class="perf-swatch baseline"></i>llama.cpp</span>
        <span class="perf-board-note">decode tok/s · higher is better</span>
      </div>
      {rdnaBoard.rows.map((row) => (
        <article class="perf-bench-row">
          <div class="perf-bench-head">
            <strong>{row.label}</strong>
            <span class:list={['perf-ratio', ratioTone(row.zincDecode, row.baselineDecode)]}>{formatRatioX(row.zincDecode, row.baselineDecode)} llama.cpp</span>
          </div>
          <div class="perf-bar">
            <span class="perf-bar-tag">ZINC</span>
            <div class="perf-track"><i class="perf-fill zinc" style={`width:${barPct(row.zincDecode, rdnaBoard.decodeMax)}%`}></i></div>
            <span class="perf-bar-val">{formatTok(row.zincDecode, 1)}</span>
          </div>
          <div class="perf-bar">
            <span class="perf-bar-tag muted">llama</span>
            <div class="perf-track"><i class="perf-fill baseline" style={`width:${barPct(row.baselineDecode, rdnaBoard.decodeMax)}%`}></i></div>
            <span class="perf-bar-val">{formatTok(row.baselineDecode, 1)}</span>
          </div>
          <p class="perf-prefill">
            Prefill <strong>{formatTok(row.zincPrefill, 0)}</strong> ZINC · {formatTok(row.baselinePrefill, 0)} llama.cpp · Overall <strong>{formatPercent(row.overallPct)}</strong>
          </p>
        </article>
      ))}
    </div>
    <p class="perf-caption">Measured with the fair server-vs-server suite: one reusable ZINC server per model, one reusable llama.cpp server per model, same GGUF files, same scenario matrix, same warmup/run count, and server-side timing. We are still cooking: the next work is widening the narrow Gemma 31B margin and extending the sweep across more scenarios.</p>
  </section>

  <section class="demo-panel">
    <img src="/zinc-chat-demo.gif" alt="ZINC Chat — streaming LLM inference on an AMD Radeon RDNA4 GPU via Vulkan" class="demo-gif" />
    <p class="demo-caption">A 35B-parameter Qwen3.6 model running locally on a single AMD Radeon GPU — Zig + Vulkan, no ROCm, no MLX</p>
    <div class="start-links">
      <a href="/zinc/docs/getting-started/">Getting Started</a>
      <a href="/zinc/docs/hardware-requirements/">Hardware Requirements</a>
      <a href="/zinc/docs/running-zinc/">Running ZINC</a>
      <a href="/zinc/docs/">All Docs</a>
    </div>
  </section>

  <section>
    <p>Consumer GPUs have the hardware for fast LLM inference, but the software stack doesn't use it well. AMD's RDNA cards — the Radeon RX 9070 XT, RX 7900 XTX, and Radeon AI PRO R9700 — are ignored by ROCm and get only generic Vulkan in llama.cpp. Apple Silicon runs MLX and llama.cpp Metal, but no engine is built from scratch around Metal's strengths. ZINC targets both platforms with hand-tuned shaders, so you can run LLM inference on an AMD GPU without ROCm.</p>

    <p><strong>ZINC is not finished productized infrastructure yet.</strong> It is an experimental engine under active development, and the best current experience is still Linux-first, AMD-first, and CLI-first. The point of the docs is to make that path explicit instead of making you reverse-engineer it from technical specs.</p>

    <p>ZINC takes a different approach. It is an inference engine written in <strong>Zig</strong> with hand-tuned <strong>Vulkan compute shaders</strong>, built specifically for the GPU architecture these cards actually have.</p>

    <h2>Why not vLLM or llama.cpp?</h2>

    <table>
      <thead>
        <tr><th></th><th>ZINC</th><th>vLLM</th><th>llama.cpp (Vulkan)</th></tr>
      </thead>
      <tbody>
        <tr><td><strong>RDNA3/RDNA4 support</strong></td><td>First-class target</td><td>Not supported (needs ROCm)</td><td>Works, no RDNA4 tuning</td></tr>
        <tr><td><strong>Continuous batching</strong></td><td>Roadmap</td><td>Built-in</td><td>Server-bolted</td></tr>
        <tr><td><strong>Paged KV cache</strong></td><td>vLLM-style PagedAttention</td><td>Yes</td><td>No (contiguous)</td></tr>
        <tr><td><strong>KV cache compression</strong></td><td>TurboQuant roadmap / experimental path</td><td>No</td><td>No</td></tr>
        <tr><td><strong>GPU kernel tuning</strong></td><td>RDNA4 wave64, coop matrix</td><td>ROCm/CUDA only</td><td>Generic Vulkan</td></tr>
        <tr><td><strong>OpenAI API</strong></td><td>Native</td><td>Native</td><td>Via server wrapper</td></tr>
      </tbody>
    </table>

    <h2>Other measured targets</h2>

    <p>The AMD board above is the headline path. We also keep publishing the younger Apple Silicon backend with the same benchmark data format, so the gaps are visible instead of hidden. Full breakdown with scenarios and run provenance lives on <a href="/zinc/benchmarks/">the benchmarks dashboard</a>.</p>

    <h3 class="perf-heading">Apple Silicon — Mac Studio (M4 Max) <span class="perf-sub">40-core GPU · 64 GB unified · {formatRefreshDate(metalTarget?.generated_at)}</span></h3>
    <div class="perf-board" role="img" aria-label="ZINC vs llama.cpp decode throughput on Apple M4 Max">
      <div class="perf-board-legend">
        <span><i class="perf-swatch zinc"></i>ZINC</span>
        <span><i class="perf-swatch baseline"></i>llama.cpp</span>
        <span class="perf-board-note">decode tok/s · higher is better</span>
      </div>
      {metalBoard.rows.map((row) => (
        <article class="perf-bench-row">
          <div class="perf-bench-head">
            <strong>{row.label}</strong>
            <span class:list={['perf-ratio', ratioTone(row.zincDecode, row.baselineDecode)]}>{formatRatioX(row.zincDecode, row.baselineDecode)} llama.cpp</span>
          </div>
          <div class="perf-bar">
            <span class="perf-bar-tag">ZINC</span>
            <div class="perf-track"><i class="perf-fill zinc" style={`width:${barPct(row.zincDecode, metalBoard.decodeMax)}%`}></i></div>
            <span class="perf-bar-val">{formatTok(row.zincDecode, 1)}</span>
          </div>
          <div class="perf-bar">
            <span class="perf-bar-tag muted">llama</span>
            <div class="perf-track"><i class="perf-fill baseline" style={`width:${barPct(row.baselineDecode, metalBoard.decodeMax)}%`}></i></div>
            <span class="perf-bar-val">{formatTok(row.baselineDecode, 1)}</span>
          </div>
          <p class="perf-prefill">Prefill <strong>{formatTok(row.zincPrefill, 0)}</strong> ZINC · {formatTok(row.baselinePrefill, 0)} llama.cpp</p>
        </article>
      ))}
    </div>
    <p class="perf-caption">Exact machine above, native Metal backend ({formatRefreshDate(metalTarget?.generated_at)} refresh) — not a generic "Apple Silicon" average. The Metal path is younger than the RDNA4 one: decode still trails llama.cpp on most models, but ZINC prefill already leads on Qwen3-8B and Gemma 4 31B. Closing the A3B decode gap is the active Metal target.</p>

    <h2>What ZINC does</h2>

    <p><strong>Two GPU backends, one engine.</strong> On AMD: <a href="/zinc/docs/rdna4-tuning/">wave64, cooperative matrix, architecture-aware tiling</a> via Vulkan compute. On Apple Silicon: <a href="/zinc/docs/apple-metal-reference/">native MSL kernels</a> with simdgroup ops, zero-copy mmap, and Metal pipeline tuning. ZINC picks the right backend at build time.</p>

    <p>The API is OpenAI-compatible: <code>POST /v1/chat/completions</code> with SSE streaming, plus a built-in chat UI with thinking mode support. Point your existing client at ZINC and it works. <a href="/zinc/docs/api/">API reference</a>.</p>

    <p>Models load from GGUF files via direct memory-map — DMA to GPU VRAM on Vulkan, zero-copy <code>newBufferWithBytesNoCopy</code> on Metal. Supports Q4_K, Q5_K, Q6_K, Q8_0, and F16 quantization. Architectures: Qwen 3 / 3.5 / 3.6 (dense and A3B MoE), Gemma 4, and SSM-hybrid paths.</p>

    <p>The whole thing is written in Zig (with a thin Objective-C shim for Metal). No hidden allocations, direct GPU API calls, comptime dispatch tables, single binary.</p>

    <h2>Architecture</h2>

    <div class="arch-diagram">
      <img src="/zinc-architecture.svg" alt="ZINC LLM inference engine architecture — Vulkan compute pipeline for AMD Radeon RDNA GPUs and Metal for Apple Silicon" width="680" />
    </div>

    <h2>Supported hardware: AMD Radeon GPUs &amp; Apple Silicon</h2>

    <p>ZINC targets AMD Radeon GPUs via Vulkan compute and Apple Silicon via Metal. No ROCm, no MLX, no heavyweight framework.</p>

    <h3>AMD Radeon GPUs — RDNA4 &amp; RDNA3 (Linux)</h3>
    <ul>
      <li><strong>RDNA4</strong>: RX 9070, RX 9070 XT, Radeon AI PRO R9700 (primary tuning target)</li>
