#version 460
// ZINC - batched Gemma full-attention K norm + RoPE + V norm + KV write.
//
// Full-attention Gemma layers use a precomputed RoPE frequency buffer, so the
// existing Q+K batched fused shader cannot also bind the page table within its
// eight-buffer shape. This K/V-only sibling keeps the frequency buffer and page
// table, while Q norm/RoPE remains on the existing standalone path.
//
// Dispatch: (n_k_heads, n_tokens, 1), local_size_x = 64.

#extension GL_KHR_shader_subgroup_arithmetic : require

layout(local_size_x = 64) in;

layout(set = 0, binding = 0) readonly buffer KSrc      { float k_src[]; };
layout(set = 0, binding = 1) readonly buffer KWeight   { float k_weight[]; };
layout(set = 0, binding = 2) readonly buffer FreqBuf   { float inv_freq[]; };
layout(set = 0, binding = 3) readonly buffer PageTable { uint  page_ids[]; };
layout(set = 0, binding = 4)          buffer KvK       { float kv_k[]; };
layout(set = 0, binding = 5) readonly buffer VSrc      { float v_src[]; };
layout(set = 0, binding = 6)          buffer KvV       { float kv_v[]; };

layout(push_constant) uniform PushConstants {
    uint head_dim;
    uint rope_dim;
    uint n_k_heads;
    uint n_tokens;
    uint page_size;
    uint base_token;
    uint freq_base_bits;
    uint attn_scale_bits;
    uint eps_bits;
    uint v_norm;
};

shared float s_partial[64];
shared float s_partial_v[64];

void main() {
    const uint tid = gl_LocalInvocationID.x;
    const uint head = gl_WorkGroupID.x;
    const uint tok = gl_WorkGroupID.y;

    const float eps = uintBitsToFloat(eps_bits);
    const uint kv_src_base = (tok * n_k_heads + head) * head_dim;
    const uint kv_dim = n_k_heads * head_dim;
    const uint logical_token = base_token + tok;
    const uint page_idx = logical_token / page_size;
    const uint page_off = logical_token % page_size;
    const uint physical_tok = page_ids[page_idx] * page_size + page_off;
    const uint kv_dst_base = physical_tok * kv_dim + head * head_dim;

    float k_sum_sq = 0.0;
    float v_sum_sq = 0.0;
    for (uint i = tid; i < head_dim; i += 64u) {
        const float k = k_src[kv_src_base + i];
        k_sum_sq += k * k;
        if (v_norm != 0u) {
            const float v = v_src[kv_src_base + i];
            v_sum_sq += v * v;
        }
    }

    k_sum_sq = subgroupAdd(k_sum_sq);
    v_sum_sq = subgroupAdd(v_sum_sq);

    if (gl_NumSubgroups > 1u) {
        if (gl_SubgroupInvocationID == 0u) {
            s_partial[gl_SubgroupID] = k_sum_sq;
            s_partial_v[gl_SubgroupID] = v_sum_sq;
        }
        barrier();
        if (tid == 0u) {
            float total_k = 0.0;
            float total_v = 0.0;
            for (uint sg = 0u; sg < gl_NumSubgroups; sg++) {
                total_k += s_partial[sg];
                total_v += s_partial_v[sg];
            }
            s_partial[0] = total_k;
            s_partial_v[0] = total_v;
        }
        barrier();
        k_sum_sq = s_partial[0];
        v_sum_sq = s_partial_v[0];
    }

    const float k_rms_inv = inversesqrt(k_sum_sq / float(head_dim) + eps);
    const float v_rms_inv = inversesqrt(v_sum_sq / float(head_dim) + eps);
    const float freq_base = uintBitsToFloat(freq_base_bits);
    const float attn_scale = attn_scale_bits != 0u ? uintBitsToFloat(attn_scale_bits) : 1.0;
    const bool use_freq_buf = (freq_base_bits == 0u);
    const uint half_rot = rope_dim / 2u;

    for (uint i = tid; i < half_rot; i += 64u) {
        const float lo = k_weight[i] * (k_src[kv_src_base + i] * k_rms_inv);
        const float hi = k_weight[i + half_rot] * (k_src[kv_src_base + i + half_rot] * k_rms_inv);

        float freq_i;
        if (use_freq_buf) {
            freq_i = inv_freq[i];
        } else {
            const float exponent = float(2u * i) / float(rope_dim);
            freq_i = 1.0 / pow(freq_base, exponent);
        }
        const float theta = float(logical_token) * freq_i;
        const float cos_t = cos(theta) * attn_scale;
        const float sin_t = sin(theta) * attn_scale;

        kv_k[kv_dst_base + i] = lo * cos_t - hi * sin_t;
        kv_k[kv_dst_base + i + half_rot] = lo * sin_t + hi * cos_t;
    }

    for (uint i = rope_dim + tid; i < head_dim; i += 64u) {
        kv_k[kv_dst_base + i] = k_weight[i] * (k_src[kv_src_base + i] * k_rms_inv);
    }

    for (uint i = tid; i < head_dim; i += 64u) {
        const float v = v_src[kv_src_base + i];
        kv_v[kv_dst_base + i] = (v_norm != 0u) ? (v * v_rms_inv) : v;
    }
}
