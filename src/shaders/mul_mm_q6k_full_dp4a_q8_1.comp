#version 460
// ZINC — int8 DP4a full-tile Q6_K GEMM for Qwen3.6-27B SSM wqkv prefill, with
// Q8_1 activation input (vec2 scale_dsum per 32-block, dsum unused).
//
// This is the same kernel as mul_mm_q6k_full_dp4a.comp; the only difference is
// the activation scale binding: this variant reads `vec2 b_scale_dsum[]` and
// uses `.x` (scale), ignoring `.y` (dsum, which Q6_K doesn't need — Q6_K
// weights have no per-block bias term, unlike Q4_K).
//
// Why: in the Qwen3.6-27B SSM segment, wqkv (Q6_K) and z (Q4_K) both quantize
// scratch_norm. The Q4_K path requires Q8_1 (needs dsum for bias correction);
// the Q6_K path only needs the scale. Sharing the Q8_1 quantize between both
// dispatches saves one quantize_act dispatch + one barrier per SSM layer
// (~32 SSM layers in the 27B model), feeding both GEMMs from a single packed
// int8 + scale_dsum buffer pair.
//
// LDS is tiny (int8 packed): ~2.7KB vs the f16 path's 6.3KB, so occupancy is no
// longer the bottleneck. Host may only dispatch when M,N are multiples of 32.

#include "dp4a_compat.glsl"
#extension GL_EXT_shader_explicit_arithmetic_types : require
#extension GL_EXT_shader_16bit_storage : require
#extension GL_EXT_control_flow_attributes : require

const uint BM = 32u;
const uint BN = 32u;
const uint BK = 32u;
const uint TM = 4u;
const uint TN = 4u;
const uint WG_SIZE = 64u;
const uint TPR_M = BM / TM; // 8
const uint TPR_N = BN / TN; // 8

const uint Q6K_BLOCK_SIZE = 256u;
const uint Q6K_BYTES = 210u;
// Packed-uint LDS row stride: 8 uints (=32 int8) per BM/BN row, +1 pad uint so
// the per-row stride (9) is coprime-ish with 32 banks -> no LDS bank conflicts
// for the strided weight/activation reads in the dot loop.
const uint SPACK = 9u;

layout(local_size_x = WG_SIZE) in;

layout(push_constant) uniform PushConstants {
    uint M;
    uint N;
    uint K;
    uint stride_b_packed; // per-column uints in the packed activation = K/4
    uint stride_b_scale;  // per-column vec2 in the activation scale_dsum = K/32
    uint stride_d;        // per-column floats in output                  = M
    uint a_offset;        // byte offset into Q6_K weights
    uint d_offset;        // float offset into output
};

layout(set = 0, binding = 0) readonly buffer MatA  { uint8_t a_data[]; };
layout(set = 0, binding = 1) readonly buffer ActB  { uint b_packed[]; };
layout(set = 0, binding = 2) readonly buffer SclB  { vec2 b_scale_dsum[]; };
layout(set = 0, binding = 3) writeonly buffer MatD { float d_data[]; };

shared uint  buf_a[BM * SPACK];   // packed int8 weights (q-32), 8 uints/row
shared float buf_aw[BM * 2u];     // Q6_K weight scale per (row, sub-block-in-tile)
shared uint  buf_b[BN * SPACK];   // packed int8 activations, 8 uints/col
shared float buf_bs[BN];          // activation scale per column (this 32-block, .x of vec2)

int signed_i8(uint b) {
    return int(b) - (b >= 128u ? 256 : 0);
}

// Dequantize a 16-wide run of Q6_K weights kb..kb+15 to signed int8 (q-32) and
// pack into 4 uints. Returns the run's weight scale s = d * i8(scale). Mirrors
// load_q6k_run in mul_mm_q6k_full.comp but keeps q-32 integral for DP4a.
void load_q6k_run_i8(uint byte_off, uint kb, out uint packed[4], out float s) {
    const uint half_id = kb >> 7;
    const uint rem0 = kb & 127u;
    const uint group = rem0 >> 5;
    const uint l0 = rem0 & 31u;          // 0 or 16
    const uint is = l0 >> 4;             // 0 or 1

    const uint ql_base = byte_off + half_id * 64u;
    const uint qh_base = byte_off + 128u + half_id * 32u;
    const uint sc_base = byte_off + 192u + half_id * 8u;

    const bool hi_nibble = (group >= 2u);
    const uint ql_off = ql_base + l0 + (((group & 1u) != 0u) ? 32u : 0u);
    const uint qh_off = qh_base + l0;
    const uint qh_shift = group * 2u;
    const uint scale_idx = is + group * 2u;

    const uint d_bits = uint(a_data[byte_off + 208u]) | (uint(a_data[byte_off + 209u]) << 8);
    const float d = unpackHalf2x16(d_bits).x;
    s = d * float(signed_i8(uint(a_data[sc_base + scale_idx])));

    [[unroll]] for (uint p = 0u; p < 4u; p++) {
        uint w = 0u;
        [[unroll]] for (uint b = 0u; b < 4u; b++) {
            const uint i = p * 4u + b;
            const uint ql_raw = uint(a_data[ql_off + i]);
            const uint ql_nib = hi_nibble ? (ql_raw >> 4) : (ql_raw & 0xFu);
            const uint qh_raw = uint(a_data[qh_off + i]);
            const int q = int(ql_nib | (((qh_raw >> qh_shift) & 3u) << 4)) - 32;
            w |= (uint(q) & 0xFFu) << (b * 8u);
        }
        packed[p] = w;
    }
}

void main() {
    const uint tid = gl_LocalInvocationID.x;
    const uint ir = gl_WorkGroupID.x;
    const uint ic = gl_WorkGroupID.y;

    const uint tiwr = tid % TPR_M;
    const uint tiwc = tid / TPR_M;

    float sums[TM][TN];
    [[unroll]] for (uint m = 0u; m < TM; m++) {
        [[unroll]] for (uint n = 0u; n < TN; n++) {
            sums[m][n] = 0.0;
        }
    }

    const uint blocks_per_row = K / Q6K_BLOCK_SIZE;

    for (uint k_outer = 0u; k_outer < K; k_outer += BK) {
        // ---- load + dequant weight half-tile (one 16-wide sub-block) ----
        {
            const uint row_local = tid / 2u;
            const uint sub = tid & 1u;          // 0 -> k 0..15, 1 -> k 16..31
            const uint k_in_tile = sub * 16u;
            const uint row_global = ir * BM + row_local;
            const uint k_base = k_outer + k_in_tile;
            const uint super_block = k_base >> 8;
            const uint byte_off = a_offset
                + row_global * blocks_per_row * Q6K_BYTES
                + super_block * Q6K_BYTES;
            const uint k_block_base = k_base & 255u;

            uint packed[4];
            float s;
            load_q6k_run_i8(byte_off, k_block_base, packed, s);

            const uint base_a = row_local * SPACK + sub * 4u;
            [[unroll]] for (uint p = 0u; p < 4u; p++) buf_a[base_a + p] = packed[p];
            buf_aw[row_local * 2u + sub] = s;
        }

        // ---- load pre-quantized int8 activation half-tile ----
        {
            const uint col_local = tid / 2u;
            const uint sub = tid & 1u;
            const uint k_in_tile = sub * 16u;
            const uint col_global = ic * BN + col_local;
            const uint src = col_global * stride_b_packed + ((k_outer + k_in_tile) >> 2);
            const uint base_b = col_local * SPACK + sub * 4u;
            [[unroll]] for (uint p = 0u; p < 4u; p++) buf_b[base_b + p] = b_packed[src + p];
            if (sub == 0u) {
                buf_bs[col_local] = b_scale_dsum[col_global * stride_b_scale + (k_outer >> 5)].x;
            }
        }

        barrier();

        // ---- int8 dot4 accumulate ----
        uint wreg[TM][8];
        float ws[TM][2];
        [[unroll]] for (uint m = 0u; m < TM; m++) {
            const uint wrow = (tiwr * TM + m) * SPACK;
            [[unroll]] for (uint p = 0u; p < 8u; p++) wreg[m][p] = buf_a[wrow + p];
            ws[m][0] = buf_aw[(tiwr * TM + m) * 2u + 0u];
            ws[m][1] = buf_aw[(tiwr * TM + m) * 2u + 1u];
        }
        [[unroll]] for (uint n = 0u; n < TN; n++) {
            const uint acol = (tiwc * TN + n) * SPACK;
            uint areg[8];
            [[unroll]] for (uint p = 0u; p < 8u; p++) areg[p] = buf_b[acol + p];
            const float as = buf_bs[tiwc * TN + n];
            [[unroll]] for (uint m = 0u; m < TM; m++) {
                int isum0 = 0;
                int isum1 = 0;
                [[unroll]] for (uint p = 0u; p < 4u; p++) {
                    isum0 = dotPacked4x8AccSatEXT(int(wreg[m][p]),      int(areg[p]),      isum0);
                    isum1 = dotPacked4x8AccSatEXT(int(wreg[m][4u + p]), int(areg[4u + p]), isum1);
                }
                sums[m][n] += as * (ws[m][0] * float(isum0) + ws[m][1] * float(isum1));
            }
        }

        barrier();
    }

    [[unroll]] for (uint m = 0u; m < TM; m++) {
        [[unroll]] for (uint n = 0u; n < TN; n++) {
            const uint row_g = ir * BM + tiwr * TM + m;
            const uint col_g = ic * BN + tiwc * TN + n;
            d_data[d_offset + col_g * stride_d + row_g] = sums[m][n];
        }
    }
}
