#version 460
// ZINC - grouped Qwen top-1 Q4_K MoE fused gate+up+SwiGLU.
//
// Route ids are packed expert-major by moe_route_pack.comp. Each workgroup
// computes four intermediate rows for up to eight token routes that selected
// the same expert. Qwen stores gate and up experts in separate tensors, so this
// shader reads both tensors and writes the SwiGLU activation directly.

#extension GL_EXT_shader_explicit_arithmetic_types : require
#extension GL_EXT_shader_16bit_storage : require
#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require
#extension GL_KHR_shader_subgroup_clustered : require

layout(local_size_x = 64) in;

layout(push_constant) uniform PushConstants {
    uint M;
    uint K;
    uint a_offset;
    uint expert_stride;
    uint up_offset;
    uint y_offset;
    uint ids_stride;
    uint x_route_divisor;
    uint x_token_base;
};

layout(set = 0, binding = 0) readonly buffer MatrixAGate { uint a_gate_u32[]; };
layout(set = 0, binding = 1) readonly buffer MatrixAUp { uint a_up_u32[]; };
layout(set = 0, binding = 2) readonly buffer VectorX { vec4 x_v4[]; };
layout(set = 0, binding = 3) writeonly buffer Output { float y_data[]; };
layout(set = 0, binding = 4) readonly buffer Counts { uint counts[]; };
layout(set = 0, binding = 5) readonly buffer PackedIds { uint packed_ids[]; };
layout(set = 0, binding = 6) readonly buffer ActiveBlocks { uint active_blocks[]; };

const uint NUM_COLS = 8u;
const uint ROWS_PER_WG = 4u;
const uint LANES_PER_ROW = 16u;
const uint Q4K_BLOCK_U32 = 36u;

vec4 unpack_nibbles_lo(uint v) {
    return vec4(float(v & 0xFu), float((v >> 8) & 0xFu),
                float((v >> 16) & 0xFu), float((v >> 24) & 0xFu));
}

vec4 unpack_nibbles_hi(uint v) {
    return vec4(float((v >> 4) & 0xFu), float((v >> 12) & 0xFu),
                float((v >> 20) & 0xFu), float((v >> 28) & 0xFu));
}

void decode_scales(uint sc0, uint sc1, uint sc2, uint shift,
                   out float sc_a, out float mn_a,
                   out float sc_b, out float mn_b,
                   out float sc_c, out float mn_c,
                   out float sc_d, out float mn_d) {
    const uint sc0_v = sc0 >> shift;
    const uint sc1_v = sc1 >> shift;
    const uint sc2_v = sc2 >> shift;

    sc_a = float(sc0_v & 0x3Fu);
    mn_a = float(sc1_v & 0x3Fu);
    sc_b = float((sc0_v >> 8u) & 0x3Fu);
    mn_b = float((sc1_v >> 8u) & 0x3Fu);
    sc_c = float((sc2_v & 0xFu) | ((sc0_v & 0xC0u) >> 2u));
    mn_c = float(((sc2_v & 0xF0u) >> 4u) | ((sc1_v & 0xC0u) >> 2u));
    sc_d = float(((sc2_v >> 8u) & 0xFu) | (((sc0_v >> 8u) & 0xC0u) >> 2u));
    mn_d = float((((sc2_v >> 8u) & 0xF0u) >> 4u) | (((sc1_v >> 8u) & 0xC0u) >> 2u));
}

void accumulate_gate_row(
    uint row_u32,
    uint block_idx,
    uint q_offset_in_half,
    uint shift,
    uint idx0,
    uint idx1,
    uint idx2,
    uint idx3,
    uint x0,
    uint x1,
    uint x2,
    uint x3,
    uint x4,
    uint x5,
    uint x6,
    uint x7,
    bool active0,
    bool active1,
    bool active2,
    bool active3,
    bool active4,
    bool active5,
    bool active6,
    bool active7,
    inout vec4 acc0,
    inout vec4 acc1
) {
    const uint blk_u32 = row_u32 + block_idx * Q4K_BLOCK_U32;
    const uint d_dmin = a_gate_u32[blk_u32];
    const float d_val = unpackHalf2x16(d_dmin & 0xFFFFu).x;
    const float dmin_val = unpackHalf2x16(d_dmin >> 16).x;

    const uint sc0 = a_gate_u32[blk_u32 + 1u];
    const uint sc1 = a_gate_u32[blk_u32 + 2u];
    const uint sc2 = a_gate_u32[blk_u32 + 3u];
    float sc_a, mn_a, sc_b, mn_b, sc_c, mn_c, sc_d, mn_d;
    decode_scales(sc0, sc1, sc2, shift, sc_a, mn_a, sc_b, mn_b, sc_c, mn_c, sc_d, mn_d);

    const uint qs_u32_0 = a_gate_u32[blk_u32 + 4u + q_offset_in_half / 4u];
    const uint qs_u32_1 = a_gate_u32[blk_u32 + 4u + q_offset_in_half / 4u + 16u];
    const vec4 q0_lo = unpack_nibbles_lo(qs_u32_0);
    const vec4 q0_hi = unpack_nibbles_hi(qs_u32_0);
    const vec4 q1_lo = unpack_nibbles_lo(qs_u32_1);
    const vec4 q1_hi = unpack_nibbles_hi(qs_u32_1);

    const float f0 = d_val * sc_a, b0 = dmin_val * mn_a;
    const float f1 = d_val * sc_b, b1 = dmin_val * mn_b;
    const float f2 = d_val * sc_c, b2 = dmin_val * mn_c;
    const float f3 = d_val * sc_d, b3 = dmin_val * mn_d;

    const vec4 w0 = vec4(f0) * q0_lo - vec4(b0);
    const vec4 w1 = vec4(f1) * q0_hi - vec4(b1);
    const vec4 w2 = vec4(f2) * q1_lo - vec4(b2);
    const vec4 w3 = vec4(f3) * q1_hi - vec4(b3);

    if (active0) acc0.x += dot(w0, x_v4[x0 + idx0]) + dot(w1, x_v4[x0 + idx1]) + dot(w2, x_v4[x0 + idx2]) + dot(w3, x_v4[x0 + idx3]);
    if (active1) acc0.y += dot(w0, x_v4[x1 + idx0]) + dot(w1, x_v4[x1 + idx1]) + dot(w2, x_v4[x1 + idx2]) + dot(w3, x_v4[x1 + idx3]);
    if (active2) acc0.z += dot(w0, x_v4[x2 + idx0]) + dot(w1, x_v4[x2 + idx1]) + dot(w2, x_v4[x2 + idx2]) + dot(w3, x_v4[x2 + idx3]);
    if (active3) acc0.w += dot(w0, x_v4[x3 + idx0]) + dot(w1, x_v4[x3 + idx1]) + dot(w2, x_v4[x3 + idx2]) + dot(w3, x_v4[x3 + idx3]);
    if (active4) acc1.x += dot(w0, x_v4[x4 + idx0]) + dot(w1, x_v4[x4 + idx1]) + dot(w2, x_v4[x4 + idx2]) + dot(w3, x_v4[x4 + idx3]);
    if (active5) acc1.y += dot(w0, x_v4[x5 + idx0]) + dot(w1, x_v4[x5 + idx1]) + dot(w2, x_v4[x5 + idx2]) + dot(w3, x_v4[x5 + idx3]);
    if (active6) acc1.z += dot(w0, x_v4[x6 + idx0]) + dot(w1, x_v4[x6 + idx1]) + dot(w2, x_v4[x6 + idx2]) + dot(w3, x_v4[x6 + idx3]);
    if (active7) acc1.w += dot(w0, x_v4[x7 + idx0]) + dot(w1, x_v4[x7 + idx1]) + dot(w2, x_v4[x7 + idx2]) + dot(w3, x_v4[x7 + idx3]);
}

void accumulate_up_row(
    uint row_u32,
    uint block_idx,
    uint q_offset_in_half,
    uint shift,
    uint idx0,
    uint idx1,
    uint idx2,
    uint idx3,
    uint x0,
    uint x1,
    uint x2,
    uint x3,
    uint x4,
    uint x5,
    uint x6,
    uint x7,
    bool active0,
    bool active1,
    bool active2,
    bool active3,
    bool active4,
    bool active5,
    bool active6,
    bool active7,
    inout vec4 acc0,
    inout vec4 acc1
) {
    const uint blk_u32 = row_u32 + block_idx * Q4K_BLOCK_U32;
    const uint d_dmin = a_up_u32[blk_u32];
    const float d_val = unpackHalf2x16(d_dmin & 0xFFFFu).x;
    const float dmin_val = unpackHalf2x16(d_dmin >> 16).x;

    const uint sc0 = a_up_u32[blk_u32 + 1u];
    const uint sc1 = a_up_u32[blk_u32 + 2u];
    const uint sc2 = a_up_u32[blk_u32 + 3u];
    float sc_a, mn_a, sc_b, mn_b, sc_c, mn_c, sc_d, mn_d;
    decode_scales(sc0, sc1, sc2, shift, sc_a, mn_a, sc_b, mn_b, sc_c, mn_c, sc_d, mn_d);

    const uint qs_u32_0 = a_up_u32[blk_u32 + 4u + q_offset_in_half / 4u];
    const uint qs_u32_1 = a_up_u32[blk_u32 + 4u + q_offset_in_half / 4u + 16u];
    const vec4 q0_lo = unpack_nibbles_lo(qs_u32_0);
    const vec4 q0_hi = unpack_nibbles_hi(qs_u32_0);
    const vec4 q1_lo = unpack_nibbles_lo(qs_u32_1);
    const vec4 q1_hi = unpack_nibbles_hi(qs_u32_1);

    const float f0 = d_val * sc_a, b0 = dmin_val * mn_a;
    const float f1 = d_val * sc_b, b1 = dmin_val * mn_b;
    const float f2 = d_val * sc_c, b2 = dmin_val * mn_c;
    const float f3 = d_val * sc_d, b3 = dmin_val * mn_d;

    const vec4 w0 = vec4(f0) * q0_lo - vec4(b0);
    const vec4 w1 = vec4(f1) * q0_hi - vec4(b1);
    const vec4 w2 = vec4(f2) * q1_lo - vec4(b2);
    const vec4 w3 = vec4(f3) * q1_hi - vec4(b3);

    if (active0) acc0.x += dot(w0, x_v4[x0 + idx0]) + dot(w1, x_v4[x0 + idx1]) + dot(w2, x_v4[x0 + idx2]) + dot(w3, x_v4[x0 + idx3]);
    if (active1) acc0.y += dot(w0, x_v4[x1 + idx0]) + dot(w1, x_v4[x1 + idx1]) + dot(w2, x_v4[x1 + idx2]) + dot(w3, x_v4[x1 + idx3]);
    if (active2) acc0.z += dot(w0, x_v4[x2 + idx0]) + dot(w1, x_v4[x2 + idx1]) + dot(w2, x_v4[x2 + idx2]) + dot(w3, x_v4[x2 + idx3]);
    if (active3) acc0.w += dot(w0, x_v4[x3 + idx0]) + dot(w1, x_v4[x3 + idx1]) + dot(w2, x_v4[x3 + idx2]) + dot(w3, x_v4[x3 + idx3]);
    if (active4) acc1.x += dot(w0, x_v4[x4 + idx0]) + dot(w1, x_v4[x4 + idx1]) + dot(w2, x_v4[x4 + idx2]) + dot(w3, x_v4[x4 + idx3]);
    if (active5) acc1.y += dot(w0, x_v4[x5 + idx0]) + dot(w1, x_v4[x5 + idx1]) + dot(w2, x_v4[x5 + idx2]) + dot(w3, x_v4[x5 + idx3]);
    if (active6) acc1.z += dot(w0, x_v4[x6 + idx0]) + dot(w1, x_v4[x6 + idx1]) + dot(w2, x_v4[x6 + idx2]) + dot(w3, x_v4[x6 + idx3]);
    if (active7) acc1.w += dot(w0, x_v4[x7 + idx0]) + dot(w1, x_v4[x7 + idx1]) + dot(w2, x_v4[x7 + idx2]) + dot(w3, x_v4[x7 + idx3]);
}

void accumulate_route_pair(
    vec4 gate_w0,
    vec4 gate_w1,
    vec4 gate_w2,
    vec4 gate_w3,
    vec4 up_w0,
    vec4 up_w1,
    vec4 up_w2,
    vec4 up_w3,
    uint x_base,
    uint idx0,
    uint idx1,
    uint idx2,
    uint idx3,
    inout float gate_acc,
    inout float up_acc
) {
    const vec4 x0v = x_v4[x_base + idx0];
    const vec4 x1v = x_v4[x_base + idx1];
    const vec4 x2v = x_v4[x_base + idx2];
    const vec4 x3v = x_v4[x_base + idx3];
    gate_acc += dot(gate_w0, x0v) + dot(gate_w1, x1v) + dot(gate_w2, x2v) + dot(gate_w3, x3v);
    up_acc += dot(up_w0, x0v) + dot(up_w1, x1v) + dot(up_w2, x2v) + dot(up_w3, x3v);
}

void accumulate_gate_up_row(
    uint row_u32,
    uint block_idx,
    uint q_offset_in_half,
    uint shift,
    uint idx0,
    uint idx1,
    uint idx2,
    uint idx3,
    uint x0,
    uint x1,
    uint x2,
    uint x3,
    uint x4,
    uint x5,
    uint x6,
    uint x7,
    bool active0,
    bool active1,
    bool active2,
    bool active3,
    bool active4,
    bool active5,
    bool active6,
    bool active7,
    inout vec4 gate0,
    inout vec4 gate1,
    inout vec4 up0,
    inout vec4 up1
) {
    const uint blk_u32 = row_u32 + block_idx * Q4K_BLOCK_U32;

    const uint gate_d_dmin = a_gate_u32[blk_u32];
    const float gate_d_val = unpackHalf2x16(gate_d_dmin & 0xFFFFu).x;
    const float gate_dmin_val = unpackHalf2x16(gate_d_dmin >> 16).x;
    const uint gate_sc0 = a_gate_u32[blk_u32 + 1u];
    const uint gate_sc1 = a_gate_u32[blk_u32 + 2u];
    const uint gate_sc2 = a_gate_u32[blk_u32 + 3u];
    float gate_sc_a, gate_mn_a, gate_sc_b, gate_mn_b, gate_sc_c, gate_mn_c, gate_sc_d, gate_mn_d;
    decode_scales(gate_sc0, gate_sc1, gate_sc2, shift, gate_sc_a, gate_mn_a, gate_sc_b, gate_mn_b, gate_sc_c, gate_mn_c, gate_sc_d, gate_mn_d);

    const uint up_d_dmin = a_up_u32[blk_u32];
    const float up_d_val = unpackHalf2x16(up_d_dmin & 0xFFFFu).x;
    const float up_dmin_val = unpackHalf2x16(up_d_dmin >> 16).x;
    const uint up_sc0 = a_up_u32[blk_u32 + 1u];
    const uint up_sc1 = a_up_u32[blk_u32 + 2u];
    const uint up_sc2 = a_up_u32[blk_u32 + 3u];
    float up_sc_a, up_mn_a, up_sc_b, up_mn_b, up_sc_c, up_mn_c, up_sc_d, up_mn_d;
    decode_scales(up_sc0, up_sc1, up_sc2, shift, up_sc_a, up_mn_a, up_sc_b, up_mn_b, up_sc_c, up_mn_c, up_sc_d, up_mn_d);

    const uint q_word_offset = 4u + q_offset_in_half / 4u;
    const uint gate_qs_u32_0 = a_gate_u32[blk_u32 + q_word_offset];
    const uint gate_qs_u32_1 = a_gate_u32[blk_u32 + q_word_offset + 16u];
    const uint up_qs_u32_0 = a_up_u32[blk_u32 + q_word_offset];
    const uint up_qs_u32_1 = a_up_u32[blk_u32 + q_word_offset + 16u];

    const vec4 gate_w0 = vec4(gate_d_val * gate_sc_a) * unpack_nibbles_lo(gate_qs_u32_0) - vec4(gate_dmin_val * gate_mn_a);
    const vec4 gate_w1 = vec4(gate_d_val * gate_sc_b) * unpack_nibbles_hi(gate_qs_u32_0) - vec4(gate_dmin_val * gate_mn_b);
    const vec4 gate_w2 = vec4(gate_d_val * gate_sc_c) * unpack_nibbles_lo(gate_qs_u32_1) - vec4(gate_dmin_val * gate_mn_c);
    const vec4 gate_w3 = vec4(gate_d_val * gate_sc_d) * unpack_nibbles_hi(gate_qs_u32_1) - vec4(gate_dmin_val * gate_mn_d);

    const vec4 up_w0 = vec4(up_d_val * up_sc_a) * unpack_nibbles_lo(up_qs_u32_0) - vec4(up_dmin_val * up_mn_a);
    const vec4 up_w1 = vec4(up_d_val * up_sc_b) * unpack_nibbles_hi(up_qs_u32_0) - vec4(up_dmin_val * up_mn_b);
    const vec4 up_w2 = vec4(up_d_val * up_sc_c) * unpack_nibbles_lo(up_qs_u32_1) - vec4(up_dmin_val * up_mn_c);
    const vec4 up_w3 = vec4(up_d_val * up_sc_d) * unpack_nibbles_hi(up_qs_u32_1) - vec4(up_dmin_val * up_mn_d);

    if (active0) accumulate_route_pair(gate_w0, gate_w1, gate_w2, gate_w3, up_w0, up_w1, up_w2, up_w3, x0, idx0, idx1, idx2, idx3, gate0.x, up0.x);
    if (active1) accumulate_route_pair(gate_w0, gate_w1, gate_w2, gate_w3, up_w0, up_w1, up_w2, up_w3, x1, idx0, idx1, idx2, idx3, gate0.y, up0.y);
    if (active2) accumulate_route_pair(gate_w0, gate_w1, gate_w2, gate_w3, up_w0, up_w1, up_w2, up_w3, x2, idx0, idx1, idx2, idx3, gate0.z, up0.z);
    if (active3) accumulate_route_pair(gate_w0, gate_w1, gate_w2, gate_w3, up_w0, up_w1, up_w2, up_w3, x3, idx0, idx1, idx2, idx3, gate0.w, up0.w);
    if (active4) accumulate_route_pair(gate_w0, gate_w1, gate_w2, gate_w3, up_w0, up_w1, up_w2, up_w3, x4, idx0, idx1, idx2, idx3, gate1.x, up1.x);
    if (active5) accumulate_route_pair(gate_w0, gate_w1, gate_w2, gate_w3, up_w0, up_w1, up_w2, up_w3, x5, idx0, idx1, idx2, idx3, gate1.y, up1.y);
    if (active6) accumulate_route_pair(gate_w0, gate_w1, gate_w2, gate_w3, up_w0, up_w1, up_w2, up_w3, x6, idx0, idx1, idx2, idx3, gate1.z, up1.z);
    if (active7) accumulate_route_pair(gate_w0, gate_w1, gate_w2, gate_w3, up_w0, up_w1, up_w2, up_w3, x7, idx0, idx1, idx2, idx3, gate1.w, up1.w);
}

float swiglu(float gate, float up) {
    const float g = clamp(gate, -60.0, 60.0);
    return gate * (1.0 / (1.0 + exp(-g))) * up;
}

void main() {
    const uint tid = gl_LocalInvocationID.x;
    const uint row_group = tid / LANES_PER_ROW;
    const uint lane = tid - row_group * LANES_PER_ROW;
    const uint row = gl_WorkGroupID.x * ROWS_PER_WG + row_group;
    if (row >= M) return;

    const uint block_entry = active_blocks[gl_WorkGroupID.y];
    if (block_entry == 0xFFFFFFFFu) return;

    const uint expert_id = block_entry & 0xFFFFu;
    const uint packed_base = (block_entry >> 16u) * NUM_COLS;
    const uint count = counts[expert_id];
    if (packed_base >= count) return;

    const bool active0 = packed_base + 0u < count;
    const bool active1 = packed_base + 1u < count;
    const bool active2 = packed_base + 2u < count;
    const bool active3 = packed_base + 3u < count;
    const bool active4 = packed_base + 4u < count;
    const bool active5 = packed_base + 5u < count;
    const bool active6 = packed_base + 6u < count;
    const bool active7 = packed_base + 7u < count;

    const uint ids_base = expert_id * ids_stride + packed_base;
    const uint route0 = active0 ? packed_ids[ids_base + 0u] : 0u;
    const uint route1 = active1 ? packed_ids[ids_base + 1u] : 0u;
    const uint route2 = active2 ? packed_ids[ids_base + 2u] : 0u;
    const uint route3 = active3 ? packed_ids[ids_base + 3u] : 0u;
    const uint route4 = active4 ? packed_ids[ids_base + 4u] : 0u;
    const uint route5 = active5 ? packed_ids[ids_base + 5u] : 0u;
    const uint route6 = active6 ? packed_ids[ids_base + 6u] : 0u;
    const uint route7 = active7 ? packed_ids[ids_base + 7u] : 0u;

    const uint x_div = max(x_route_divisor, 1u);
    const uint x0 = (x_token_base + route0 / x_div) * (K / 4u);
    const uint x1 = (x_token_base + route1 / x_div) * (K / 4u);
    const uint x2 = (x_token_base + route2 / x_div) * (K / 4u);
    const uint x3 = (x_token_base + route3 / x_div) * (K / 4u);
    const uint x4 = (x_token_base + route4 / x_div) * (K / 4u);
    const uint x5 = (x_token_base + route5 / x_div) * (K / 4u);
    const uint x6 = (x_token_base + route6 / x_div) * (K / 4u);
    const uint x7 = (x_token_base + route7 / x_div) * (K / 4u);

    const uint il = lane / 4u;
    const uint ir = lane & 3u;
    const uint v_im = il / 2u;
    const uint v_in = il & 1u;
    const uint l0 = 4u * (2u * ir + v_in);
    const uint q_offset_in_half = 32u * v_im + l0;
    const uint y_offset_local = 64u * v_im + l0;
    const uint shift = v_im * 16u;

    const uint blocks_per_row = K / 256u;
    const uint expert_base_u32 = (a_offset + expert_id * expert_stride) / 4u;
    const uint gate_row_u32 = expert_base_u32 + row * blocks_per_row * Q4K_BLOCK_U32;
    const uint up_row_u32 = expert_base_u32 + row * blocks_per_row * Q4K_BLOCK_U32;

    vec4 gate0 = vec4(0.0);
    vec4 gate1 = vec4(0.0);
    vec4 up0 = vec4(0.0);
    vec4 up1 = vec4(0.0);

    for (uint b = 0u; b < blocks_per_row; b++) {
        const uint idx0 = (b * 256u + y_offset_local) / 4u;
        const uint idx1 = idx0 + 8u;
        const uint idx2 = (b * 256u + y_offset_local + 128u) / 4u;
        const uint idx3 = idx2 + 8u;

        accumulate_gate_up_row(gate_row_u32, b, q_offset_in_half, shift, idx0, idx1, idx2, idx3, x0, x1, x2, x3, x4, x5, x6, x7, active0, active1, active2, active3, active4, active5, active6, active7, gate0, gate1, up0, up1);
    }

    const float gate_out0 = subgroupClusteredAdd(gate0.x, LANES_PER_ROW);
    const float gate_out1 = subgroupClusteredAdd(gate0.y, LANES_PER_ROW);
    const float gate_out2 = subgroupClusteredAdd(gate0.z, LANES_PER_ROW);
    const float gate_out3 = subgroupClusteredAdd(gate0.w, LANES_PER_ROW);
    const float gate_out4 = subgroupClusteredAdd(gate1.x, LANES_PER_ROW);
    const float gate_out5 = subgroupClusteredAdd(gate1.y, LANES_PER_ROW);
    const float gate_out6 = subgroupClusteredAdd(gate1.z, LANES_PER_ROW);
    const float gate_out7 = subgroupClusteredAdd(gate1.w, LANES_PER_ROW);
    const float up_out0 = subgroupClusteredAdd(up0.x, LANES_PER_ROW);
    const float up_out1 = subgroupClusteredAdd(up0.y, LANES_PER_ROW);
    const float up_out2 = subgroupClusteredAdd(up0.z, LANES_PER_ROW);
    const float up_out3 = subgroupClusteredAdd(up0.w, LANES_PER_ROW);
    const float up_out4 = subgroupClusteredAdd(up1.x, LANES_PER_ROW);
    const float up_out5 = subgroupClusteredAdd(up1.y, LANES_PER_ROW);
    const float up_out6 = subgroupClusteredAdd(up1.z, LANES_PER_ROW);
    const float up_out7 = subgroupClusteredAdd(up1.w, LANES_PER_ROW);

    if (lane == 0u) {
        const uint y_base = y_offset / 4u;
        if (active0) y_data[y_base + route0 * M + row] = swiglu(gate_out0, up_out0);
        if (active1) y_data[y_base + route1 * M + row] = swiglu(gate_out1, up_out1);
        if (active2) y_data[y_base + route2 * M + row] = swiglu(gate_out2, up_out2);
        if (active3) y_data[y_base + route3 * M + row] = swiglu(gate_out3, up_out3);
        if (active4) y_data[y_base + route4 * M + row] = swiglu(gate_out4, up_out4);
        if (active5) y_data[y_base + route5 * M + row] = swiglu(gate_out5, up_out5);
        if (active6) y_data[y_base + route6 * M + row] = swiglu(gate_out6, up_out6);
        if (active7) y_data[y_base + route7 * M + row] = swiglu(gate_out7, up_out7);
    }
}
