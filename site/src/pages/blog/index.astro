---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const topicLinks = [
  {
    label: 'Qwen3.6',
    href: '/topics/qwen3-6-local-inference/',
  },
  {
    label: 'Gemma 4',
    href: '/topics/gemma-local-inference/',
  },
  {
    label: 'AMD RDNA4',
    href: '/topics/amd-rdna4-llm-inference/',
  },
  {
    label: 'KV cache',
    href: '/topics/kv-cache-quantization/',
  },
];
---

<BaseLayout
  title="Local LLM Inference Blog"
  description="Technical posts on ZINC, Qwen3.6, Gemma 4, AMD RDNA4, Vulkan and Metal local LLM inference, KV cache quantization, and GPU performance."
  keywords="ZINC blog, local LLM inference, Qwen3.6, Gemma 4, AMD GPU, RDNA4, Vulkan compute, Metal inference, TurboQuant, GPU optimization, local AI, systems engineering"
>
  <h1>Local LLM Inference Blog</h1>
  <p class="intro">Technical notes on building ZINC, GPU programming, and making local AI work on hardware people actually own.</p>

  <nav class="guide-links" aria-label="Related topic guides">
    <span class="guide-links-label">Related guides</span>
    {topicLinks.map((topic, index) => (
      <>
        <a href={topic.href}>{topic.label}</a>
        {index < topicLinks.length - 1 && <span class="guide-separator" aria-hidden="true">/</span>}
      </>
    ))}
  </nav>

  <section>
    {posts.map(post => (
      <PostCard
        title={post.data.title}
        date={post.data.date}
        excerpt={post.data.excerpt}
        slug={post.id}
        tags={post.data.tags}
      />
    ))}
  </section>
</BaseLayout>

<style>
  .intro {
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .guide-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0.55rem;
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: 0.86rem;
  }

  .guide-links-label {
    color: var(--color-text-muted);
    font-weight: 700;
  }

  .guide-links a {
    color: var(--color-text);
    font-weight: 700;
    text-decoration: none;
  }

  .guide-links a:hover {
    color: var(--color-accent);
  }

  .guide-separator {
    color: var(--color-border);
  }

  @media (max-width: 600px) {
    .guide-links-label {
      width: 100%;
    }
  }
</style>
