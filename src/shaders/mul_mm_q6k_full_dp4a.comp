#version 460
// ZINC — int8 DP4a full-tile Q6_K GEMM for Qwen3.6-27B dense-down prefill.
//
// The f32-FMA Q6_K GEMM (mul_mm_q6k_full.comp) is a tuned local optimum: cycle
// 19 (occupancy-lift via f16 activations) and cycle 22 (better LDS:FMA via wide
// tiles) both regressed, leaving it pinned at ~44% of f32 FMA peak. The only
// lever that raises arithmetic throughput is to drop the inner product to the
// hardware int8 dot4 (v_dot4_i32_i8 / OpSDot PackedVectorFormat4x8Bit), which
// does 4 MACs per instruction. RDNA4 (GFX1201) has no exposed coopmat, so int8
// DP4a is the intended replacement.
//
// Q6_K weights are 6-bit, so the dequantized value q-32 (range [-32,31]) is
// exact in int8 — no extra weight error. Activations arrive pre-quantized to
// int8 with a per-32-block scale (quantize_act_q8.comp, Q8_0-style), so the only
// new error is the standard W6A8 activation quant, scaled locally per 32 to stay
// robust on the unnormalized SwiGLU output.
//
// Math: out[m,n] = sum_tiles ascale[n,tile] * (ws[m,sub0]*dot(q,qB)_sub0
//                                              + ws[m,sub1]*dot(q,qB)_sub1)
// where ws[m,sub] = d * i8(q6k_scale) is the Q6_K weight scale (NOT folded into
// the int8 weight), and the int dot uses the q-32 weights against int8 acts.
//
// LDS is tiny (int8 packed): ~2.7KB vs the f16 path's 6.3KB, so occupancy is no
// longer the bottleneck. Host may only dispatch when M,N are multiples of 32.

#include "dp4a_compat.glsl"
#extension GL_EXT_shader_explicit_arithmetic_types : require
#extension GL_EXT_shader_16bit_storage : require
#extension GL_EXT_control_flow_attributes : require

const uint BM = 32u;
const uint BK = 32u;
const uint TM = 4u;
const uint WG_SIZE = 64u;
const uint TPR_M = BM / TM; // 8

const uint Q6K_BLOCK_SIZE = 256u;
const uint Q6K_BYTES = 210u;
// Packed-uint LDS row stride: 8 uints (=32 int8) per BM/BN row, +1 pad uint so
// the per-row stride (9) is coprime-ish with 32 banks -> no LDS bank conflicts
// for the strided weight/activation reads in the dot loop.
const uint SPACK = 9u;

layout(constant_id = 0) const uint SPEC_K = 0u;
layout(constant_id = 1) const uint SPEC_BN = 32u;
layout(constant_id = 2) const uint SPEC_RAGGED_N = 0u;
layout(constant_id = 3) const uint SPEC_BK_STEP = 1u;
layout(constant_id = 4) const uint SPEC_ACCUMULATE = 0u;

const uint BN = SPEC_BN;
const uint BK_STEP = SPEC_BK_STEP;
const uint TPR_N = WG_SIZE / TPR_M; // 8
const uint TN = BN / TPR_N;

layout(local_size_x = WG_SIZE) in;

layout(push_constant) uniform PushConstants {
    uint M;
    uint N;
    uint K;
    uint stride_b_packed; // per-column uints in the packed activation = K/4
    uint stride_b_scale;  // per-column floats in the activation scale  = K/32
    uint stride_d;        // per-column floats in output                = M
    uint a_offset;        // byte offset into Q6_K weights
    uint d_offset;        // float offset into output
};

layout(set = 0, binding = 0) readonly buffer MatA  { uint8_t a_data[]; };
layout(set = 0, binding = 1) readonly buffer ActB  { uint b_packed[]; };
layout(set = 0, binding = 2) readonly buffer SclB  { float b_scale[]; };
layout(set = 0, binding = 3) writeonly buffer MatD { float d_data[]; };

shared uint  buf_a[BK_STEP * BM * SPACK];   // packed int8 weights (q-32), 8 uints/row
shared float buf_aw[BK_STEP * BM * 2u];     // Q6_K weight scale per (row, sub-block-in-tile)
shared uint  buf_b[BK_STEP * BN * SPACK];   // packed int8 activations, 8 uints/col
shared float buf_bs[BK_STEP * BN];          // activation scale per column (this 32-block)

int signed_i8(uint b) {
    return int(b) - (b >= 128u ? 256 : 0);
}

// Dequantize a 16-wide run of Q6_K weights kb..kb+15 to signed int8 (q-32) and
// pack into 4 uints. Returns the run's weight scale s = d * i8(scale). Mirrors
// load_q6k_run in mul_mm_q6k_full.comp but keeps q-32 integral for DP4a.
void load_q6k_run_i8(uint byte_off, uint kb, out uint packed[4], out float s) {
    const uint half_id = kb >> 7;
    const uint rem0 = kb & 127u;
    const uint group = rem0 >> 5;
    const uint l0 = rem0 & 31u;          // 0 or 16
    const uint is = l0 >> 4;             // 0 or 1

    const uint ql_base = byte_off + half_id * 64u;
    const uint qh_base = byte_off + 128u + half_id * 32u;
    const uint sc_base = byte_off + 192u + half_id * 8u;

    const bool hi_nibble = (group >= 2u);
    const uint ql_off = ql_base + l0 + (((group & 1u) != 0u) ? 32u : 0u);
    const uint qh_off = qh_base + l0;
    const uint qh_shift = group * 2u;
    const uint scale_idx = is + group * 2u;

    const uint d_bits = uint(a_data[byte_off + 208u]) | (uint(a_data[byte_off + 209u]) << 8);
    const float d = unpackHalf2x16(d_bits).x;
    s = d * float(signed_i8(uint(a_data[sc_base + scale_idx])));

    [[unroll]] for (uint p = 0u; p < 4u; p++) {
        uint w = 0u;
        [[unroll]] for (uint b = 0u; b < 4u; b++) {
            const uint i = p * 4u + b;
            const uint ql_raw = uint(a_data[ql_off + i]);
            const uint ql_nib = hi_nibble ? (ql_raw >> 4) : (ql_raw & 0xFu);
            const uint qh_raw = uint(a_data[qh_off + i]);
            const int q = int(ql_nib | (((qh_raw >> qh_shift) & 3u) << 4)) - 32;
            w |= (uint(q) & 0xFFu) << (b * 8u);
        }
        packed[p] = w;
    }
}

void main() {
    const uint tid = gl_LocalInvocationID.x;
    const uint ir = gl_WorkGroupID.x;
    const uint ic = gl_WorkGroupID.y;

    const uint tiwr = tid % TPR_M;
    const uint tiwc = tid / TPR_M;

    float sums[TM][TN];
    [[unroll]] for (uint m = 0u; m < TM; m++) {
        [[unroll]] for (uint n = 0u; n < TN; n++) {
            sums[m][n] = 0.0;
        }
    }

    const uint k_limit = (SPEC_K != 0u) ? SPEC_K : K;
    const uint blocks_per_row = k_limit / Q6K_BLOCK_SIZE;
    const uint b_stride_packed = (SPEC_K != 0u) ? (SPEC_K / 4u) : stride_b_packed;
    const uint b_stride_scale = (SPEC_K != 0u) ? (SPEC_K / 32u) : stride_b_scale;

    for (uint k_outer = 0u; k_outer < k_limit; k_outer += BK * BK_STEP) {
        // ---- load + dequant weight half-tile (one 16-wide sub-block) ----
        [[unroll]] for (uint ks = 0u; ks < BK_STEP; ks++) {
            const uint k_step_base = k_outer + ks * BK;
            const uint row_local = tid / 2u;
            const uint sub = tid & 1u;          // 0 -> k 0..15, 1 -> k 16..31
            const uint k_in_tile = sub * 16u;
            const uint row_global = ir * BM + row_local;
            const uint k_base = k_step_base + k_in_tile;
            const uint super_block = k_base >> 8;
            const uint byte_off = a_offset
                + row_global * blocks_per_row * Q6K_BYTES
                + super_block * Q6K_BYTES;
            const uint k_block_base = k_base & 255u;

            uint packed[4];
            float s;
            load_q6k_run_i8(byte_off, k_block_base, packed, s);

            const uint base_a = ks * BM * SPACK + row_local * SPACK + sub * 4u;
            [[unroll]] for (uint p = 0u; p < 4u; p++) buf_a[base_a + p] = packed[p];
            buf_aw[ks * BM * 2u + row_local * 2u + sub] = s;
        }

        // ---- load pre-quantized int8 activation half-tile ----
        [[unroll]] for (uint ks = 0u; ks < BK_STEP; ks++) {
            const uint k_step_base = k_outer + ks * BK;
            const uint sub = tid & 1u;
            const uint k_in_tile = sub * 16u;
            if (BN >= 32u) {
                [[unroll]] for (uint cbase = 0u; cbase < BN; cbase += 32u) {
                    const uint col_local = cbase + tid / 2u;
                    if (col_local < BN) {
                        const uint col_global = ic * BN + col_local;
                        const bool col_ok = SPEC_RAGGED_N == 0u || col_global < N;
                        const uint src = col_global * b_stride_packed + ((k_step_base + k_in_tile) >> 2);
                        const uint base_b = ks * BN * SPACK + col_local * SPACK + sub * 4u;
                        [[unroll]] for (uint p = 0u; p < 4u; p++) {
                            buf_b[base_b + p] = col_ok ? b_packed[src + p] : 0u;
                        }
                        if (sub == 0u) {
                            buf_bs[ks * BN + col_local] = col_ok ? b_scale[col_global * b_stride_scale + (k_step_base >> 5)] : 0.0;
                        }
                    }
                }
            } else {
                const uint col_local = tid >> 3;
                const uint pack_idx = tid & 7u;
                const uint col_global = ic * BN + col_local;
                const bool col_ok = col_global < N;
                const uint base_b = ks * BN * SPACK + col_local * SPACK;
                buf_b[base_b + pack_idx] = col_ok
                    ? b_packed[col_global * b_stride_packed + (k_step_base >> 2) + pack_idx]
                    : 0u;
                if (pack_idx == 0u) {
                    buf_bs[ks * BN + col_local] = col_ok
                        ? b_scale[col_global * b_stride_scale + (k_step_base >> 5)]
                        : 0.0;
                }
            }
        }

        barrier();

        // ---- int8 dot4 accumulate ----
        [[unroll]] for (uint ks = 0u; ks < BK_STEP; ks++) {
            uint wreg[TM][8];
            float ws[TM][2];
            [[unroll]] for (uint m = 0u; m < TM; m++) {
                const uint wrow = ks * BM * SPACK + (tiwr * TM + m) * SPACK;
                [[unroll]] for (uint p = 0u; p < 8u; p++) wreg[m][p] = buf_a[wrow + p];
                ws[m][0] = buf_aw[ks * BM * 2u + (tiwr * TM + m) * 2u + 0u];
                ws[m][1] = buf_aw[ks * BM * 2u + (tiwr * TM + m) * 2u + 1u];
            }
            [[unroll]] for (uint n = 0u; n < TN; n++) {
                const uint acol = ks * BN * SPACK + (tiwc * TN + n) * SPACK;
                uint areg[8];
                [[unroll]] for (uint p = 0u; p < 8u; p++) areg[p] = buf_b[acol + p];
                const float as = buf_bs[ks * BN + tiwc * TN + n];
                [[unroll]] for (uint m = 0u; m < TM; m++) {
                    int isum0 = 0;
                    int isum1 = 0;
                    [[unroll]] for (uint p = 0u; p < 4u; p++) {
                        isum0 = dotPacked4x8AccSatEXT(int(wreg[m][p]),      int(areg[p]),      isum0);
                        isum1 = dotPacked4x8AccSatEXT(int(wreg[m][4u + p]), int(areg[4u + p]), isum1);
                    }
                    sums[m][n] += as * (ws[m][0] * float(isum0) + ws[m][1] * float(isum1));
                }
            }
        }

        barrier();
    }

    [[unroll]] for (uint m = 0u; m < TM; m++) {
        [[unroll]] for (uint n = 0u; n < TN; n++) {
            const uint row_g = ir * BM + tiwr * TM + m;
            const uint col_g = ic * BN + tiwc * TN + n;
            if (SPEC_RAGGED_N == 0u || col_g < N) {
                const uint out_idx = d_offset + col_g * stride_d + row_g;
                if (SPEC_ACCUMULATE != 0u) {
                    d_data[out_idx] += sums[m][n];
                } else {
                    d_data[out_idx] = sums[m][n];
                }
            }
        }
    }
}
